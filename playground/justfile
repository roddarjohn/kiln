config := "examples/project.jsonnet"
out    := "_generated"

# List available recipes
default:
    @just --list

# Generate everything from the project config (wipes output first)
generate:
    uv run --project .. kiln generate --config {{ config }} --out {{ out }} --clean

alias g := generate

# Generate then start the dev server (hot-reload)
fresh: generate serve

alias f := fresh

# Start the dev server (hot-reload)
serve:
    uv run --project .. --group playground uvicorn main:app --reload

alias s := serve

# Apply all pending migrations to head
migrate:
    uv run --group playground alembic upgrade head

# Generate a new autogenerated migration revision
migration msg="auto":
    uv run --group playground alembic revision --autogenerate -m "{{msg}}"
