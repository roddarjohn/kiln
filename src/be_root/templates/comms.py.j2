class DbPreferenceResolver:
    """Database-backed :class:`ingot.comms.PreferenceResolver`.

    Reads one row from
    ``{{ module }}.models.NotificationPreference`` per call.
    Default policy: an absent row reads as **opt-in** -- flip the
    fallback in :meth:`is_enabled` if your project defaults to
    opt-out (regulatory contexts often require this).

    Opens its own short-lived session per call so the request's
    transaction isn't blocked on the preference lookup.  For a
    high-fan-out send (50+ recipients per message) consider
    pre-fetching all preferences for the batch and feeding the
    resolver a closure that reads from a dict instead of the DB.
    """

    async def is_enabled(
        self,
        *,
        subject_key: str,
        comm_type: str,
        method: str,
    ) -> bool:
        """Return ``True`` to deliver, ``False`` to suppress."""
        async with _session_factory() as session:
            row = (
                await session.execute(
                    select(NotificationPreference.enabled).where(
                        NotificationPreference.subject_key == subject_key,
                        NotificationPreference.comm_type == comm_type,
                        NotificationPreference.method == method,
                    ),
                )
            ).scalar_one_or_none()

        # Absent row defaults to opt-in.  Flip to ``False`` for
        # opt-out-by-default policies.
        return True if row is None else bool(row)


resolver = DbPreferenceResolver()
