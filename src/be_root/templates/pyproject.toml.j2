# ============================================================
# AUTOGENERATED by be_root from bootstrap.jsonnet.
#
# This file is a one-shot scaffold.  Edit it freely -- you'll
# almost certainly add more dependencies and tighten the ruff
# config as the project grows.  But re-running `just bootstrap`
# (or `foundry generate --target be_root`) overwrites this
# file verbatim; be_root has no merge semantics, so treat any
# post-bootstrap edits as "re-apply on next re-bootstrap".
# ============================================================

[project]
name = "{{ name }}"
version = "0.1.0"
description = "{{ description }}"
requires-python = ">=3.14"
dependencies = [
  "fastapi>=0.115",
  "sqlalchemy[asyncio]>=2.0",
  "asyncpg>=0.29",
  "uvicorn[standard]>=0.30",
  # ``pyjwt`` powers the JWT helpers in ``ingot.auth`` that
  # be's auth scaffold composes; ``python-multipart`` is what
  # FastAPI uses to parse OAuth2-style form bodies on the
  # generated ``POST /auth/token`` route.  Cheap to ship even
  # when auth is off, expensive to discover missing later.
  "pyjwt>=2.0",
  "python-multipart>=0.0.22",
{% if psycopg %}
  # psycopg powers the sync engine be's auth.validate_login
  # uses.  The generated ``POST /auth/token`` route is sync (it
  # consumes a plain BaseModel, not a coroutine), so the user
  # lookup can't ride the asyncpg-backed session pool the rest
  # of the app uses.
  "psycopg[binary]>=3.2",
{% endif %}
{% if pgcraft %}
  "pgcraft",
{% endif %}
{% if kiln_extras %}
  "kiln-generator[{{ kiln_extras | join(',') }}]",
{% else %}
  "kiln-generator",
{% endif %}
]

[dependency-groups]
dev = [
  "httpx>=0.28.1",
  "pytest>=8",
  "pytest-asyncio>=1.3.0",
  "ruff>=0.15.5",
]

[tool.ruff]
line-length = 80
exclude = ["{{ package_prefix }}"]

[tool.ruff.lint]
select = ["ALL"]
ignore = [
  "COM812",
  "ISC001",
  "D203",
  "D213",
  "D100",
  "D104",
  "AIR",
  "DJ",
  "FAST",
  "NPY",
  "PD",
  "INT",
  "CPY",
]

[tool.ruff.lint.per-file-ignores]
"**/models/**" = [
  "RUF012",  # mutable __table_args__ is standard SQLAlchemy
  "TC003",   # datetime used at runtime by SQLAlchemy
]
"**/actions.py" = [
  "ARG001",  # action signatures match be's expected interface
  "TC001",   # model imports used at runtime by be
  "TC002",   # AsyncSession used at runtime by be
]
"tests/**" = [
  "S101",
  "S106",
  "ANN",
  "D",
  "PLR2004",
  "PLC0415",
  "RUF059",
  "SLF001",
  "S607",
  "S108",
  "PLW1510",
]

[tool.pytest.ini_options]
addopts = "-v"
asyncio_mode = "auto"
{% if editable %}

# Editable local installs for development against unreleased
# kiln-generator (and pgcraft) changes.  Drop this block before
# publishing -- the path-based sources won't resolve outside the
# author's machine.
[tool.uv.sources]
kiln-generator = { path = "../kiln", editable = true }
{% if pgcraft %}
pgcraft = { path = "../pgcraft", editable = true }
{% endif %}
{% endif %}
