# ============================================================
# AUTOGENERATED by be_root from bootstrap.jsonnet.
# Re-running `just bootstrap` overwrites this file verbatim.
# ============================================================
#
# Alembic configuration for {{ name }}.
#
# Migrations live under migrations/. The env.py wires
# pgcraft's alembic hooks so views, INSTEAD OF triggers, and
# functions emit alongside the raw tables on `alembic upgrade
# head`. Without those hooks, only the raw tables would be
# created and the BE's runtime lookups (which target the
# public views) would fail.

[alembic]
script_location = %(here)s/migrations
prepend_sys_path = .
path_separator = os

# DATABASE_URL drives the connection; env.py reads it.
sqlalchemy.url = driver://user:pass@localhost/dbname

[post_write_hooks]
hooks = ruff-format
ruff-format.type = exec
ruff-format.executable = uv
ruff-format.options = run ruff format REVISION_SCRIPT_FILENAME

[loggers]
keys = root,sqlalchemy,alembic,pgcraft

[handlers]
keys = console

[formatters]
keys = generic

[logger_root]
level = WARNING
handlers = console
qualname =

[logger_pgcraft]
level = INFO
handlers = console
qualname = pgcraft

[logger_sqlalchemy]
level = WARNING
handlers =
qualname = sqlalchemy.engine

[logger_alembic]
level = INFO
handlers =
qualname = alembic

[handler_console]
class = StreamHandler
args = (sys.stderr,)
level = NOTSET
formatter = generic

[formatter_generic]
format = %(levelname)-5.5s [%(name)s] %(message)s
datefmt = %H:%M:%S
