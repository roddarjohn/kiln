// ============================================================
// AUTOGENERATED by be_root from bootstrap.jsonnet.
//
// This file is a one-shot scaffold.  Edit it freely -- most
// apps add auth, telemetry, more databases, or extra apps
// here.  But running `just bootstrap` overwrites this file
// verbatim; be_root has no merge semantics, so treat any
// post-bootstrap edits as "re-apply on next re-bootstrap".
// ============================================================
//
// Project-level configuration for {{ name }}.
//
// Declares databases and apps in one place.  Run be with::
//
//   just generate
//
// See https://roddarjohn.github.io/kiln/ for the full schema.

local db = import "be/db/databases.libsonnet";
{% if auth %}
local auth = import "be/auth/jwt.libsonnet";
{% endif %}
{% if opentelemetry %}
local telemetry = import "be/telemetry/telemetry.libsonnet";
{% endif %}
{% if rate_limit %}
local rate_limit = import "be/rate_limit/rate_limit.libsonnet";
{% endif %}
{% if comms %}
local comms = import "be/comms/comms.libsonnet";
{% endif %}

{
{% if auth %}
  // Consumer owns the three domain types (LoginCredentials,
  // Session, validate_login -- all in ``auth.py``).  Kiln owns
  // the auth package -- the ``get_session`` dep and the
  // POST/GET/POST-logout endpoints under ``token_url``.
  auth: auth.jwt({
    credentials_schema: "auth.LoginCredentials",
    session_schema: "auth.Session",
    validate_fn: "auth.validate_login",
    sources: ["bearer", "cookie"],
    cookie_secure: false,  // local HTTP dev; flip true under HTTPS
    secret_env: "JWT_SECRET",
    token_url: "/auth/token",
  }),

{% endif %}
  databases: [
    db.postgres("primary", { default: true }),
  ],
{% if opentelemetry %}

  // OpenTelemetry: traces + metrics by default.  The deployment
  // environment is read at startup from ``ENVIRONMENT``; the
  // OTLP endpoint comes from ``OTEL_EXPORTER_OTLP_ENDPOINT``.
  telemetry: telemetry.otel("{{ name }}"),
{% endif %}
{% if rate_limit %}

  // Rate limiting: slowapi backed by a Postgres counter table.
  // The bucket model is a SQLAlchemy class mixing in
  // ``ingot.rate_limit.RateLimitBucketMixin`` -- you own the
  // table, kiln owns the columns.  The dotted path below is a
  // placeholder; replace it with your real model location.
  rate_limit: rate_limit.slowapi("{{ module }}.models.RateLimitBucket"),
{% endif %}
{% if comms %}

  // Communication platform: typed messages dispatched via
  // pgqueuer (transactional outbox).  The dotted paths below
  // point at the stub ``comms.py`` be_root scaffolded; replace
  // the message / recipient model paths with your real model
  // locations once you've added them.
  comms: comms.platform({
    message_model: "{{ module }}.models.CommMessage",
    recipient_model: "{{ module }}.models.CommRecipient",
    transports: {
      email: "comms.email_transport",
    },
    preferences: "comms.resolver",
    types: [
      comms.type({
        name: "welcome",
        context_schema: "comms.WelcomeContext",
        subject_template: {% raw %}"Welcome, {{ name }}!"{% endraw %},
        body_template: {% raw %}"Hi {{ name }}, glad you're here."{% endraw %},
        default_methods: ["email"],
      }),
    ],
  }),
{% endif %}

  apps: [
    { config: import "{{ module }}.jsonnet", prefix: "/{{ module }}" },
  ],
}
