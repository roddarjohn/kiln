"""Generated link registry for app `{{ module }}`.

Maps each opted-in resource's slug (lowercase model class name)
to an async builder ``(instance, session) -> LinkSchema`` and
to a ref resolver ``(ids, db, session) -> (items, dropped)``.

* The ``LINKS`` mapping powers ``_values`` endpoints and any
  user code that wants the resource's link shape.
* The ``REF_RESOLVERS`` mapping powers saved-view hydration and
  any user-supplied serializer that resolves stored ref ids
  through :func:`ingot.saved_views.hydrate_view`.
"""

from __future__ import annotations

from typing import Any

from sqlalchemy import select
from sqlalchemy.ext.asyncio import AsyncSession

from ingot.links import {{ link_class_names | join(", ") }}

{% for module, names in model_imports %}
from {{ module }} import {{ names | join(", ") }}
{% endfor %}
{% for module, names in builder_imports %}
from {{ module }} import {{ names | join(", ") }}
{% endfor %}

{% for entry in entries %}
{% if not entry.is_user_builder %}


async def {{ entry.fn_name }}(obj: {{ entry.model_class }}, session: Any) -> {{ entry.link_class }}:
{% if entry.kind == "name" %}
    return {{ entry.link_class }}(
        type="{{ entry.slug }}",
        name=obj.{{ entry.name_attr }},
    )
{% elif entry.kind == "id" %}
    return {{ entry.link_class }}(
        type="{{ entry.slug }}",
        id=obj.{{ entry.id_attr }},
    )
{% else %}
    return {{ entry.link_class }}(
        type="{{ entry.slug }}",
        id=obj.{{ entry.id_attr }},
        name=obj.{{ entry.name_attr }},
    )
{% endif %}
{% endif %}


async def {{ entry.resolver_fn_name }}(
    ids: list[Any],
    db: AsyncSession,
    session: Any,
) -> tuple[list[dict[str, Any]], int]:
    """Fetch {{ entry.model_class }} rows by id and run them
    through ``{{ entry.fn_name }}``.

    Returns ``(items, dropped)``: ``items`` are
    ``model_dump()``-ed link instances ordered to match *ids*;
    ``dropped`` counts ids that didn't resolve to a row (deleted,
    hidden, or never existed).
    """
    if not ids:
        return [], 0

    stmt = select({{ entry.model_class }}).where(
        {{ entry.model_class }}.{{ entry.pk_attr }}.in_(ids),
    )
    rows = (await db.execute(stmt)).scalars().all()
    by_id = {getattr(row, "{{ entry.pk_attr }}"): row for row in rows}

    items: list[dict[str, Any]] = []
    dropped = 0

    for raw_id in ids:
        row = by_id.get(raw_id)

        if row is None:
            dropped += 1
            continue

        link = await {{ entry.fn_name }}(row, session)
        items.append(link.model_dump())

    return items, dropped
{% endfor %}


LINKS: dict[str, Any] = {
{% for entry in entries %}
    "{{ entry.slug }}": {{ entry.fn_name }},
{% endfor %}
}


REF_RESOLVERS: dict[str, Any] = {
{% for entry in entries %}
    "{{ entry.slug }}": {{ entry.resolver_fn_name }},
{% endfor %}
}
