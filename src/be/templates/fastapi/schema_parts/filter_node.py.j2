class {{ model_name }}FilterCondition(BaseModel):
    """A single filter condition for {{ model_name }}."""

    field: Literal[{{ allowed_fields | map('tojson') | join(', ') }}]
    op: Literal[
        "eq",
        "neq",
        "gt",
        "gte",
        "lt",
        "lte",
        "contains",
        "starts_with",
        "in",
    ] = "eq"
    value: Any = None


class {{ model_name }}FilterExpression(BaseModel):
    """Recursive AND/OR filter expression for {{ model_name }}."""

    model_config = ConfigDict(populate_by_name=True)

    and_: list[{{ model_name }}FilterCondition | {{ model_name }}FilterExpression] | None = Field(
        None, alias="and"
    )
    or_: list[{{ model_name }}FilterCondition | {{ model_name }}FilterExpression] | None = Field(
        None, alias="or"
    )


{{ model_name }}FilterExpression.model_rebuild()
