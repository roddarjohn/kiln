# -------------------------------------------------------------------
# Request bodies — narrowed to known slugs / fields so the FE
# OpenAPI client can constrain inputs at compile time.
# -------------------------------------------------------------------


class ProjectFilterDiscoveryRequest(BaseModel):
    """Project-narrowed counterpart of :class:`FilterDiscoveryRequest`.

    ``resources`` is constrained to the registered slugs at codegen
    time, so callers can't ask for a resource that doesn't exist.
    Same semantics as the ingot base: ``None`` returns every
    registered resource.
    """

    resources: list[ResourceSlug] | None = None


class ProjectFieldDiscoveryRequest(BaseModel):
    """Project-narrowed counterpart of :class:`FieldDiscoveryRequest`.

    ``fields`` carries one of the per-resource ``*FieldRef`` typed
    references; the union is discriminated on ``resource`` so a
    valid combination of ``(resource, field)`` is enforced at the
    schema layer.
    """

    fields: list[RegisteredFieldRef] = Field(default_factory=list)
