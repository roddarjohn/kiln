from __future__ import annotations

from typing import Annotated

from fastapi import APIRouter, Depends
from sqlalchemy.ext.asyncio import AsyncSession

from ingot.filter_values import FilterValuesRequest
from ingot.resource_registry import (
    FieldDiscoveryRequest,
    FieldRef,
    FieldsDiscovery as IngotFieldsDiscovery,
    FilterDiscoveryRequest,
    ProjectDiscovery as IngotProjectDiscovery,
    ValuesPage,
)

from {{ schemas_module }} import (
    Discovery,
    FieldsDiscovery,
    ProjectFieldDiscoveryRequest,
    ProjectFilterDiscoveryRequest,
    RegisteredValuesRequest,
)

from {{ session_module }} import {{ get_db_fn }}
{% if require_auth %}
from {{ auth_module }} import get_session
from {{ session_schema_module }} import {{ session_schema_name }}
{% endif %}

from {{ registry_module }} import resource_registry

router = APIRouter()


@router.post("/_filters", response_model=Discovery)
def filters_discovery(
    body: ProjectFilterDiscoveryRequest,
{% if require_auth %}
    session: Annotated[{{ session_schema_name }}, Depends(get_session)],
{% endif %}
) -> IngotProjectDiscovery:
    """Return the project discovery payload, narrowed by ``body.resources``.

    Registry returns the ingot generic shape; FastAPI's
    ``response_model=Discovery`` re-validates into the
    discriminated codegen union for the wire format and OpenAPI
    schema — no manual round-trip needed.
    """
    return resource_registry.filter_discovery(
        FilterDiscoveryRequest(resources=body.resources),
    )


@router.post("/_filters/fields", response_model=FieldsDiscovery)
def filter_fields_discovery(
    body: ProjectFieldDiscoveryRequest,
{% if require_auth %}
    session: Annotated[{{ session_schema_name }}, Depends(get_session)],
{% endif %}
) -> IngotFieldsDiscovery:
    """Return one :class:`FieldDiscovery` per requested ``(resource, field)``.

    Order is preserved.  ``response_model=FieldsDiscovery`` (the
    codegen-side discriminated shape) handles the per-resource
    union narrowing on serialisation.
    """
    return resource_registry.field_discovery(
        FieldDiscoveryRequest(
            fields=[
                FieldRef(resource=ref.resource, field=ref.field)
                for ref in body.fields
            ],
        ),
    )


@router.post("/_values", response_model=ValuesPage)
async def values(
    body: RegisteredValuesRequest,
    db: Annotated[AsyncSession, Depends({{ get_db_fn }})],
{% if require_auth %}
    session: Annotated[{{ session_schema_name }}, Depends(get_session)],
{% endif %}
) -> ValuesPage:
    """Single values endpoint covering every dispatch path.

    The body is discriminated on ``resource`` so the FE OpenAPI
    client picks the right per-resource shape; ``field`` is
    constrained to the resource's filter fields (or ``None`` for
    the resource-level search).  The registry handles the actual
    dispatch.
    """
    return await resource_registry.values(
        resource=body.resource,
        field=body.field,
        request=FilterValuesRequest(
            q=body.q, cursor=body.cursor, limit=body.limit,
        ),
        db=db,
{% if require_auth %}
        session=session,
{% endif %}
    )
