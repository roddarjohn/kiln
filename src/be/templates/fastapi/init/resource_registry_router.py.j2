Four thin handlers backed entirely by
:class:`ingot.resource_registry.ResourceRegistry`:

* ``POST /_filters`` — full or filtered project discovery.
  Body: :class:`ProjectFilterDiscoveryRequest`
  (``resources: list[ResourceSlug] | None``).  Returns
  :class:`Discovery`.
* ``POST /_filters/fields`` — discovery for a list of typed
  ``(resource, field)`` references.
  Body: :class:`ProjectFieldDiscoveryRequest`.  Returns
  :class:`FieldsDiscovery`.
* ``POST /_values/{resource}`` — resource-level search.
* ``POST /_values/{resource}/{field}`` — per-field value provider.

Discovery responses use codegen-side discriminated unions
(:data:`RegisteredResource` discriminated on ``resource``;
per-resource unions discriminated on ``field``) so the FE-side
OpenAPI client narrows automatically.

Mount this router in your app once::

    from {{ registry_module }}.router import router as resource_router
    app.include_router(resource_router)
{% endset %}
{{ file_header("Project-wide resource registry endpoints", extra=_extra) }}


from __future__ import annotations

from typing import Annotated

from fastapi import APIRouter, Depends
from sqlalchemy.ext.asyncio import AsyncSession

from ingot.filter_values import FilterValuesRequest
from ingot.resource_registry import (
    FieldDiscoveryRequest,
    FieldRef,
    FilterDiscoveryRequest,
    ValuesPage,
)

from {{ schemas_module }} import (
    Discovery,
    FieldsDiscovery,
    ProjectFieldDiscoveryRequest,
    ProjectFilterDiscoveryRequest,
)

from {{ session_module }} import {{ get_db_fn }}
{% if require_auth %}
from {{ auth_module }} import get_session
from {{ session_schema_module }} import {{ session_schema_name }}
{% endif %}

from {{ registry_module }} import resource_registry

router = APIRouter()


@router.post("/_filters", response_model=Discovery)
def filters_discovery(
    body: ProjectFilterDiscoveryRequest,
{% if require_auth %}
    session: Annotated[{{ session_schema_name }}, Depends(get_session)],
{% endif %}
) -> Discovery:
    """Return the project discovery payload, narrowed by ``body.resources``.

    ``body.resources is None`` returns every registered resource
    (full project payload); a list narrows to that subset; an
    empty list returns ``{"resources": []}``.
    """
    return resource_registry.filter_discovery(
        FilterDiscoveryRequest(resources=body.resources),
    )


@router.post("/_filters/fields", response_model=FieldsDiscovery)
def filter_fields_discovery(
    body: ProjectFieldDiscoveryRequest,
{% if require_auth %}
    session: Annotated[{{ session_schema_name }}, Depends(get_session)],
{% endif %}
) -> FieldsDiscovery:
    """Return one :class:`FieldDiscovery` per requested ``(resource, field)``.

    Order is preserved so callers can pair the response list
    against the request list by index.
    """
    return resource_registry.field_discovery(
        FieldDiscoveryRequest(
            fields=[
                FieldRef(resource=ref.resource, field=ref.field)
                for ref in body.fields
            ],
        ),
    )


@router.post("/_values/{resource}", response_model=ValuesPage)
async def values_resource(
    resource: str,
    body: FilterValuesRequest,
    db: Annotated[AsyncSession, Depends({{ get_db_fn }})],
{% if require_auth %}
    session: Annotated[{{ session_schema_name }}, Depends(get_session)],
{% endif %}
) -> ValuesPage:
    """Resource-level search; routes to the registry's link builder."""
    return await resource_registry.values(
        resource=resource,
        field=None,
        request=body,
        db=db,
{% if require_auth %}
        session=session,
{% endif %}
    )


@router.post("/_values/{resource}/{field}", response_model=ValuesPage)
async def values_resource_field(
    resource: str,
    field: str,
    body: FilterValuesRequest,
    db: Annotated[AsyncSession, Depends({{ get_db_fn }})],
{% if require_auth %}
    session: Annotated[{{ session_schema_name }}, Depends(get_session)],
{% endif %}
) -> ValuesPage:
    """Per-field value provider (enum / free-text / ref / self)."""
    return await resource_registry.values(
        resource=resource,
        field=field,
        request=body,
        db=db,
{% if require_auth %}
        session=session,
{% endif %}
    )
