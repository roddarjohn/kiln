{% extends "fastapi/handler_default.py.j2" %}
{% block body %}
    stmt = select({{ model_name }})
{% if load_options|default([]) %}
    stmt = stmt.options(
{% for opt in load_options %}
        {{ opt }},
{% endfor %}
    )

{% endif %}
{% if has_filter %}
    if body.filter is not None:
        stmt = apply_filters(stmt, body.filter, {{ model_name }})

{% endif %}
{% if has_sort %}
    stmt = apply_ordering(
        stmt,
        body.sort,
        {{ model_name }},
        default_field="{{ default_sort_field }}",
        default_dir="{{ default_sort_dir }}",
    )

{% endif %}
{% if pagination_mode == "keyset" %}
    stmt, page_size = apply_keyset_pagination(
        stmt,
        {{ model_name }},
        cursor=body.cursor,
        cursor_field="{{ cursor_field }}",
        page_size=body.page_size,
        max_page_size={{ max_page_size }},
    )

    result = await db.execute(stmt)
    rows = list(result.scalars())

{% if include_actions|default(false) %}
    rows = await filter_visible(
        rows,
        session,
        find_can({{ collection_specs_const }}, "list"),
    )
{% endif %}
    has_more = len(rows) > page_size
    items = rows[:page_size]
    next_cursor = (
        str(getattr(items[-1], "{{ cursor_field }}"))
        if has_more and items
        else None
    )

    return {{ model_name }}Page(
{% if custom_serializer|default(false) %}
        items=[await {{ serializer_fn }}(obj, session, db) for obj in items],
{% elif serializer_async|default(false) %}
        items=[await {{ serializer_fn }}(obj, session) for obj in items],
{% else %}
        items=[{{ serializer_fn }}(obj) for obj in items],
{% endif %}
        next_cursor=next_cursor,
    )
{% elif pagination_mode == "offset" %}
    stmt, count_stmt, effective_limit = apply_offset_pagination(
        stmt,
        offset=body.offset,
        limit=body.limit,
        max_page_size={{ max_page_size }},
    )

    total = (await db.execute(count_stmt)).scalar_one()
    # ceil(total / effective_limit), clamped at 0 when there
    # are no rows so callers don't render a phantom "Page 1".
    total_pages = (
        (total + effective_limit - 1) // effective_limit
        if total > 0
        else 0
    )

    result = await db.execute(stmt)
    rows = list(result.scalars())

{% if include_actions|default(false) %}
    rows = await filter_visible(
        rows,
        session,
        find_can({{ collection_specs_const }}, "list"),
    )
{% endif %}

    return {{ model_name }}Page(
{% if custom_serializer|default(false) %}
        items=[await {{ serializer_fn }}(obj, session, db) for obj in rows],
{% elif serializer_async|default(false) %}
        items=[await {{ serializer_fn }}(obj, session) for obj in rows],
{% else %}
        items=[{{ serializer_fn }}(obj) for obj in rows],
{% endif %}
        total=total,
        total_pages=total_pages,
    )
{% else %}
    result = await db.execute(stmt)
    rows = list(result.scalars())
{% if include_actions|default(false) %}
    rows = await filter_visible(
        rows,
        session,
        find_can({{ collection_specs_const }}, "list"),
    )
{% endif %}
{% if custom_serializer|default(false) %}
    return [await {{ serializer_fn }}(obj, session, db) for obj in rows]
{% elif serializer_async|default(false) %}
    return [await {{ serializer_fn }}(obj, session) for obj in rows]
{% else %}
    return [{{ serializer_fn }}(obj) for obj in rows]
{% endif %}
{% endif %}
{% endblock %}
