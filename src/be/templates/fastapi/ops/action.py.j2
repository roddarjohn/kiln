{% extends "fastapi/handler_default.py.j2" %}
{% from "fastapi/ops/_gate.py.j2" import gate %}
{% block body %}
{%- set model_kwarg %}{% if model_class_param_name %}, {{ model_class_param_name }}={{ model_name }}{% endif %}{% endset %}
{%- set body_kwarg %}{% if has_request_body %}, body=body{% endif %}{% endset %}
{% if is_object_action %}
    {{ model_param_name }} = await get_object_from_query_or_404(
        db,
        select({{ model_name }}).where({{ model_name }}.{{ pk_name }} == {{ pk_name }}),
        detail="{{ model_name }} not found",
    )
{{ gate(gate_specs_const|default(none), gate_op_name|default(""), model_param_name) }}
{% if returns_none %}
    await {{ fn_name }}({{ model_param_name }}, db=db{{ model_kwarg }}{{ body_kwarg }})
{% else %}
    result = await {{ fn_name }}({{ model_param_name }}, db=db{{ model_kwarg }}{{ body_kwarg }})
{% endif %}
{% else %}
{{ gate(gate_specs_const|default(none), gate_op_name|default(""), "None") }}
{% if returns_none %}
    await {{ fn_name }}(db=db{{ model_kwarg }}{{ body_kwarg }})
{% else %}
    result = await {{ fn_name }}(db=db{{ model_kwarg }}{{ body_kwarg }})
{% endif %}
{% endif %}
    await db.commit()
{% if not returns_none %}
    return result
{% endif %}
{% endblock %}
