{% extends "fastapi/handler_default.py.j2" %}
{% block body %}
    stmt = select(SavedView).where(
        SavedView.id == view_id,
        SavedView.resource_type == "{{ slug }}",
        SavedView.owner_id == str(session.user_id),
    )
    view = (await db.execute(stmt)).scalar_one_or_none()

    if view is None:
        raise HTTPException(status_code=404, detail="Saved view not found")

    if body.name is not None:
        view.name = body.name

    if body.payload is not None:
        view.payload = body.payload

    await db.commit()
    await db.refresh(view)
    return dump_view(view)
{% endblock %}
