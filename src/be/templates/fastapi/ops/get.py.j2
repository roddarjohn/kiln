{% extends "fastapi/handler_default.py.j2" %}
{% block body %}
{% if load_options|default([]) %}
    stmt = select({{ model_name }}).where(
        {{ model_name }}.{{ pk_name }} == {{ pk_name }},
    ).options(
{% for opt in load_options %}
        {{ opt }},
{% endfor %}
    )
    obj = await get_object_from_query_or_404(
        db, stmt, detail="{{ model_name }} not found",
    )
{% else %}
    obj = await get_object_from_query_or_404(
        db,
        select({{ model_name }}).where({{ model_name }}.{{ pk_name }} == {{ pk_name }}),
        detail="{{ model_name }} not found",
    )
{% endif %}
{% if gate_specs_const|default(none) %}
    if not await find_can({{ gate_specs_const }}, "{{ gate_op_name }}")(obj, session):
        raise HTTPException(status_code=403, detail="Forbidden")
{% endif %}
{% if serializer_async|default(false) %}
    return await {{ serializer_fn }}(obj, session)
{% else %}
    return {{ serializer_fn }}(obj)
{% endif %}
{% endblock %}
