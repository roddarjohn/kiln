{% extends "fastapi/handler_default.py.j2" %}
{% block body %}
    view = SavedView(
        resource_type="{{ slug }}",
        owner_id=str(session.user_id),
        name=body.name,
        payload=body.payload,
    )
    db.add(view)
    await db.commit()
    await db.refresh(view)
    return dump_view(view)
{% endblock %}
