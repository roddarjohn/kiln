{% set _extra %}
Each resource that opts into the action framework exposes two
tuples:

* ``{{ resources[0].object_const }}``
* ``{{ resources[0].collection_const }}``

Generated route handlers and serializers iterate these tuples to
populate the ``actions`` field on responses, drive the
``/permissions`` endpoint, and gate handler execution on the
same guards.
{% endset %}
{{ file_header("Generated action registries for the " ~ module ~ " app", extra=_extra) }}


from ingot.actions import ActionSpec, always_true
{% for module_path, names in guard_imports %}
from {{ module_path }} import {{ names | join(", ") }}
{% endfor %}

{% for resource in resources %}

{{ resource.object_const }} = (
{% for action in resource.object_actions %}
    ActionSpec(name="{{ action.name }}", can={{ action.can }}, is_object_action=True),
{% endfor %}
)

{{ resource.collection_const }} = (
{% for action in resource.collection_actions %}
    ActionSpec(name="{{ action.name }}", can={{ action.can }}, is_object_action=False),
{% endfor %}
)
{% endfor %}
