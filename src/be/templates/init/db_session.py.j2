{% from "_macros.j2" import file_header %}
{% set _desc = "Async SQLAlchemy session factory" ~ (" for the '" ~ key ~ "' database" if key else "") %}
{% set _extra %}
The database URL is read from the ``{{ url_env }}`` environment
variable at startup.
{% endset %}
{{ file_header(_desc, extra=_extra, tagline="Generated by ``be init``.  Modify as needed.") }}


import os
from collections.abc import AsyncGenerator

from sqlalchemy.ext.asyncio import (
    AsyncSession,
    async_sessionmaker,
    create_async_engine,
)

{% set _env_line = 'os.environ.get("' ~ url_env ~ '", "postgresql+asyncpg://localhost/dev"),' %}
_engine = create_async_engine(
{% if _env_line | length + 4 > 80 %}
    os.environ.get(
        "{{ url_env }}", "postgresql+asyncpg://localhost/dev"
    ),
{% else %}
    {{ _env_line }}
{% endif %}
    echo={{ echo }},
    pool_size={{ pool_size }},
    max_overflow={{ max_overflow }},
    pool_timeout={{ pool_timeout }},
    pool_recycle={{ pool_recycle }},
    pool_pre_ping={{ pool_pre_ping }},
)

{% if instrument_sqlalchemy %}
# OpenTelemetry: instrument the engine so each query becomes a
# client span.  The instrumentor hooks the underlying sync engine
# of the async wrapper, so spans show up under whichever request
# span is currently active.
from opentelemetry.instrumentation.sqlalchemy import (  # noqa: E402
    SQLAlchemyInstrumentor,
)

SQLAlchemyInstrumentor().instrument(engine=_engine.sync_engine)

{% endif %}
_SessionLocal = async_sessionmaker(
    _engine,
    class_=AsyncSession,
    expire_on_commit=False,
)


async def {{ get_db_fn }}() -> AsyncGenerator[AsyncSession, None]:
    """Yield an async database session.

    Intended for use as a FastAPI dependency::

        DB = Annotated[AsyncSession, Depends({{ get_db_fn }})]
    """
    async with _SessionLocal() as session:
        yield session
