import { useState } from "react";
import {
  AppShell,
  AppShellNav,
  AppShellNavItem,
{% if user_menu %}
  Avatar,
  Button,
  Inline,
{% endif %}
  Heading,
  Stack,
{% if user_menu %}
  Text,
  useAuth,
  useSession,
{% endif %}
} from "@roddarjohn/glaze";

{% for view in resource_views %}
import { {{ view.list_component }} } from "{{ view.list_module }}";
{% endfor %}
{% if user_menu %}
import type { {{ auth.session_type }} } from "./_generated/types.gen";
{% endif %}

type View =
{%- for item in nav %}
  | {{ item.view | tojson }}
{%- endfor %};

export function Shell() {
{% if user_menu %}
  const auth = useAuth();
  const session = useSession<{{ auth.session_type }}>();
{% endif %}
  const [view, setView] = useState<View>({{ default_view | tojson }});

  const sidebar = (
    <AppShellNav
      brand={<strong>{{ brand }}</strong>}
{% if user_menu %}
      footer={
        <Stack gap="2">
          <Inline gap="2">
            <Avatar name={String(session.sub ?? "")} size="sm" />
            <div>
              <Text size="sm" weight="medium">
                {String(session.sub ?? "")}
              </Text>
              <Text size="xs" tone="muted">
                {(session.roles ?? []).join(", ") || "no roles"}
              </Text>
            </div>
          </Inline>
          <Button
            variant="secondary"
            size="sm"
            onPress={() => {
              void auth.logout();
            }}
          >
            Sign out
          </Button>
        </Stack>
      }
{% endif %}
    >
{% for item in nav %}
      <AppShellNavItem
        active={view === {{ item.view | tojson }}}
        onPress={() => {
          setView({{ item.view | tojson }});
        }}
      >
        {{ item.label }}
      </AppShellNavItem>
{% endfor %}
    </AppShellNav>
  );

  return (
    <AppShell sidebar={sidebar}>
      <main style={ { padding: "1.5rem" } }>
        <Stack gap="4">
          <Heading level={1}>
            {
{% for item in nav %}
              view === {{ item.view | tojson }} ? {{ item.label | tojson }} :
{% endfor %}
              ""
            }
          </Heading>
{% for item in nav %}
{% if item.component %}
          {view === {{ item.view | tojson }} ? <{{ item.component }} /> : null}
{% endif %}
{% endfor %}
        </Stack>
      </main>
    </AppShell>
  );
}
