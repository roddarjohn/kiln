import { Suspense } from "react";
import { Outlet, useLocation, useRouter } from "@tanstack/react-router";
import {
  AppShell,
  AppShellNav,
  AppShellNavItem,
  PageContent,
  PageLoader,
{% if user_menu %}
  UserMenu,
  useAuth,
  useSession,
{% endif %}
} from "@roddarjohn/glaze";
{% if icon_names %}
import {
{% for name in icon_names %}
  {{ name }},
{% endfor %}
} from "lucide-react";
{% endif %}

{% if user_menu %}
import type { {{ auth.session_type }} } from "./_generated/types.gen";
{% endif %}

export function Shell() {
{% if user_menu %}
  const auth = useAuth();
  const session = useSession<{{ auth.session_type }}>();
{% endif %}
  const router = useRouter();
  const location = useLocation();

  const sidebar = (
    <AppShellNav
      brand={<strong>{{ brand }}</strong>}
{% if user_menu %}
      footer={
        <UserMenu
          name={String(session.sub ?? "")}
          description={(session.roles ?? []).join(", ") || "no roles"}
          onSignOut={() => {
            void auth.logout();
          }}
        />
      }
{% endif %}
    >
{% for item in nav %}
      <AppShellNavItem
        active={location.pathname.startsWith({{ ('/' + item.view) | tojson }})}
{% if item.icon %}
        icon={<{{ item.icon }} size={16} />}
{% endif %}
        onPress={() => {
          // ``search: {}`` resets any list-state search params
          // when switching resources -- otherwise routes with
          // typed validateSearch reject the navigate() call.
          void router.navigate({
            to: {{ ('/' + item.view) | tojson }},
            search: {},
          });
        }}
      >
        {{ item.label }}
      </AppShellNavItem>
{% endfor %}
    </AppShellNav>
  );

  return (
    <AppShell sidebar={sidebar}>
      <PageContent>
        {/*
         * The Suspense boundary catches ``useSuspenseQuery`` calls
         * inside route components (Detail, Update form, …) so the
         * glaze ``<PageLoader>`` fills the content area while data
         * loads -- no per-component ``isLoading`` branches.
         */}
        <Suspense fallback={<PageLoader />}>
          <Outlet />
        </Suspense>
      </PageContent>
    </AppShell>
  );
}
