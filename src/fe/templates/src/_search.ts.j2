// Type-narrowing helpers used by per-route ``validateSearch`` in
// ``src/router.tsx``.  URL search values arrive as ``unknown``
// (string when typed by the user, native types when passed via
// ``navigate({ search })``).  Anything malformed collapses to
// ``undefined`` so the URL never blocks the page from rendering.
{% if needs_string %}
export function asString(v: unknown): string | undefined {
  return typeof v === "string" && v.length > 0 ? v : undefined;
}
{% endif %}
{% if needs_number %}

export function asNumber(v: unknown): number | undefined {
  if (typeof v === "number" && Number.isFinite(v)) return v;
  if (typeof v === "string" && v.length > 0) {
    const n = Number(v);
    return Number.isFinite(n) ? n : undefined;
  }
  return undefined;
}
{% endif %}
{% if needs_bool %}

export function asBool(v: unknown): boolean | undefined {
  if (typeof v === "boolean") return v;
  if (v === "true" || v === "1") return true;
  if (v === "false" || v === "0") return false;
  return undefined;
}
{% endif %}
{% if needs_enum %}

export function asEnum<T extends string>(
  v: unknown,
  allowed: readonly T[],
): T | undefined {
  return typeof v === "string" && (allowed as readonly string[]).includes(v)
    ? (v as T)
    : undefined;
}
{% endif %}
