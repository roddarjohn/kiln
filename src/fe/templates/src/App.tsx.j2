{% if auth %}
import {
  AuthProvider,
  PageLoader,
  ToastRegion,
  useAuth,
} from "@roddarjohn/glaze";
{% else %}
import { ToastRegion } from "@roddarjohn/glaze";
{% endif %}
import { RouterProvider } from "@tanstack/react-router";

import "./api/client";
{% if auth %}
import { login, logout, validate } from "./api/auth";
{% endif %}
import { router } from "./router";

import type { ReactElement } from "react";
{% if auth %}
import type {
  {{ auth.credentials_type }},
  {{ auth.session_type }},
} from "./_generated/types.gen";
{% endif %}

export default function App(): ReactElement {
  return (
    <>
{% if auth %}
      <AuthProvider<{{ auth.session_type }}, {{ auth.credentials_type }}>
        storage={{ auth.storage | tojson }}
        validate={validate}
        login={login}
        logout={logout}
      >
        <RouterWithAuth />
      </AuthProvider>
{% else %}
      <RouterProvider router={router} />
{% endif %}
      <ToastRegion />
    </>
  );
}

{% if auth %}
/*
 * Threads the live ``useAuth()`` value into the TSR router context
 * so root-level ``beforeLoad`` hooks can gate access without
 * touching React.  While auth is resolving we show a global
 * PageLoader -- the ``RouterProvider`` doesn't mount until we know
 * the user's status, which keeps ``beforeLoad`` simple.
 */
function RouterWithAuth(): ReactElement {
  const auth = useAuth();
  if (auth.status === "loading") {
    return <PageLoader />;
  }
  return <RouterProvider router={router} context={ { auth } } />;
}
{% endif %}
