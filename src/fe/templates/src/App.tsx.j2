{% if auth %}
import { AuthProvider, ToastRegion, useAuth } from "@roddarjohn/glaze";
{% else %}
import { ToastRegion } from "@roddarjohn/glaze";
{% endif %}

import "./api/client";
{% if auth %}
import { login, logout, validate } from "./api/auth";
import { Login } from "./auth/Login";
{% endif %}
{% if has_shell %}
import { Shell } from "./Shell";
{% elif first_view_component %}
import { {{ first_view_component }} } from "{{ first_view_module }}";
{% endif %}

import type { ReactElement } from "react";
{% if auth %}
import type {
  {{ auth.credentials_type }},
  {{ auth.session_type }},
} from "./_generated/types.gen";
{% endif %}

export default function App(): ReactElement {
  return (
    <>
{% if auth %}
      <AuthProvider<{{ auth.session_type }}, {{ auth.credentials_type }}>
        storage={{ auth.storage | tojson }}
        validate={validate}
        login={login}
        logout={logout}
      >
        <AuthGate />
      </AuthProvider>
{% else %}
{% if has_shell %}
      <Shell />
{% elif first_view_component %}
      <{{ first_view_component }} />
{% else %}
      <main>No views configured.</main>
{% endif %}
{% endif %}
      <ToastRegion />
    </>
  );
}

{% if auth %}
function AuthGate(): ReactElement {
  const auth = useAuth();
  if (auth.status === "loading") {
    return (
      <main
        style={ {
          minHeight: "100vh",
          display: "grid",
          placeItems: "center",
        } }
      >
        Loading…
      </main>
    );
  }
  if (auth.status === "authenticated") {
{% if has_shell %}
    return <Shell />;
{% elif first_view_component %}
    return <{{ first_view_component }} />;
{% else %}
    return <></>;
{% endif %}
  }
  return <Login />;
}
{% endif %}
