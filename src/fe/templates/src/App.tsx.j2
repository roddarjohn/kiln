{% if auth %}
import { AuthProvider, ToastRegion, useAuth } from "@roddarjohn/glaze";
{% else %}
import { ToastRegion } from "@roddarjohn/glaze";
{% endif %}
import { RouterProvider } from "@tanstack/react-router";

import "./api/client";
{% if auth %}
import { login, logout, validate } from "./api/auth";
import { Login } from "./auth/Login";
{% endif %}
import { router } from "./router";

import type { ReactElement } from "react";
{% if auth %}
import type {
  {{ auth.credentials_type }},
  {{ auth.session_type }},
} from "./_generated/types.gen";
{% endif %}

export default function App(): ReactElement {
  return (
    <>
{% if auth %}
      <AuthProvider<{{ auth.session_type }}, {{ auth.credentials_type }}>
        storage={{ auth.storage | tojson }}
        validate={validate}
        login={login}
        logout={logout}
      >
        <AuthGate />
      </AuthProvider>
{% else %}
      <RouterProvider router={router} />
{% endif %}
      <ToastRegion />
    </>
  );
}

{% if auth %}
function AuthGate(): ReactElement {
  const auth = useAuth();
  if (auth.status === "loading") {
    return (
      <main
        style={ {
          minHeight: "100vh",
          display: "grid",
          placeItems: "center",
        } }
      >
        Loading…
      </main>
    );
  }
  if (auth.status === "authenticated") {
    return <RouterProvider router={router} />;
  }
  return <Login />;
}
{% endif %}
