// ============================================================
// AUTOGENERATED by `foundry generate --target fe`.
// Edits will be overwritten -- change config/fe.jsonnet instead.
// ============================================================

import {
{% if auth_enabled %}
  createRootRouteWithContext,
{% else %}
  createRootRoute,
{% endif %}
  createRoute,
  createRouter,
  Outlet,
{% if first_component or auth_enabled %}
  redirect,
{% endif %}
} from "@tanstack/react-router";
import { ErrorPage, PageLoader } from "@roddarjohn/glaze";

import { Shell } from "./Shell";
{% if auth_enabled %}
import { Login } from "./auth/Login";
import type { useAuth } from "@roddarjohn/glaze";
{% endif %}

{% for route in routes %}
import { make{{ route.pascal }}Routes } from "./{{ route.key }}/routes";
{% endfor %}

// Default error / not-found UI for every route.  ``reset`` (when
// supplied by TSR) clears the error boundary so the route
// remounts; ``goBack`` pops the browser history.
function RouterError({
  error,
  reset,
}: {
  error: Error;
  reset?: () => void;
}) {
  return (
    <ErrorPage
      error={error}
      reset={reset}
      goBack={() => window.history.back()}
    />
  );
}

function RouterNotFound() {
  return (
    <ErrorPage
      status={404}
      title="Page not found"
      description="The page you’re looking for doesn’t exist."
      goBack={() => window.history.back()}
    />
  );
}

{% if auth_enabled %}
// Auth state injected as TSR context so route-level ``beforeLoad``
// hooks can gate access without reaching for React.
export interface RouterContext {
  auth: ReturnType<typeof useAuth>;
}

const rootRoute = createRootRouteWithContext<RouterContext>()({
  component: () => <Outlet />,
  errorComponent: RouterError,
  notFoundComponent: RouterNotFound,
});

// Public route -- sits OUTSIDE the auth layout so the redirect
// below never traps the user on /login itself.  The optional
// ``redirect`` search param carries the URL the user was trying
// to reach so a successful login can return them there.
const loginRoute = createRoute({
  getParentRoute: () => rootRoute,
  path: "/login",
  component: Login,
  validateSearch: (search: Record<string, unknown>): {
    redirect?: string;
  } => ({
    redirect:
      typeof search.redirect === "string" && search.redirect.length > 0
        ? search.redirect
        : undefined,
  }),
});

// Pathless layout: every authenticated route renders inside
// Shell.  ``beforeLoad`` runs before the route component mounts,
// so unauth requests bounce to /login without a render flash.
const appLayoutRoute = createRoute({
  getParentRoute: () => rootRoute,
  id: "_app",
  component: Shell,
  beforeLoad: ({ context, location }) => {
    if (context.auth.status === "unauthenticated") {
      throw redirect({
        to: "/login",
        search: { redirect: location.pathname },
      });
    }
  },
});
{% else %}
const rootRoute = createRootRoute({
  component: Shell,
  errorComponent: RouterError,
  notFoundComponent: RouterNotFound,
});

const appLayoutRoute = rootRoute;
{% endif %}

const indexRoute = createRoute({
  getParentRoute: () => appLayoutRoute,
  path: "/",
{% if first_component %}
  // The index redirects to the first resource's list path so a
  // fresh visit to "/" lands the user on a real page (and any
  // ``useSearch({ from: "/<key>" })`` inside the list page finds
  // an active match).
  beforeLoad: () => {
    throw redirect({ to: {{ index_redirect | tojson }}, search: {} });
  },
{% else %}
  component: () => <Outlet />,
{% endif %}
});

{% for route in routes %}
const {{ route.key }}Routes = make{{ route.pascal }}Routes(appLayoutRoute);
{% endfor %}

const routeTree = rootRoute.addChildren([
{% if auth_enabled %}
  loginRoute,
{% endif %}
  appLayoutRoute.addChildren([
    indexRoute,
{% for route in routes %}
    ...{{ route.key }}Routes,
{% endfor %}
  ]),
]);

export const router = createRouter({
  routeTree,
{% if auth_enabled %}
  // ``context`` is set per-render by ``RouterProvider`` in
  // ``App.tsx`` (which threads in the live ``useAuth()`` value);
  // this default just satisfies the type system at startup.
  context: {
    auth: undefined as unknown as RouterContext["auth"],
  },
{% endif %}
  defaultErrorComponent: RouterError,
  defaultNotFoundComponent: RouterNotFound,
  defaultPendingComponent: () => <PageLoader />,
});

declare module "@tanstack/react-router" {
  interface Register {
    router: typeof router;
  }
}
