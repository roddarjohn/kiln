import {
  createRootRoute,
  createRoute,
  createRouter,
{% if not first_component %}
  Outlet,
{% endif %}
} from "@tanstack/react-router";

import { Shell } from "./Shell";
{% for route in routes %}
import { {{ route.list_component }} } from "{{ route.list_module }}";
{% endfor %}

const rootRoute = createRootRoute({ component: Shell });

const indexRoute = createRoute({
  getParentRoute: () => rootRoute,
  path: "/",
{% if first_component %}
  component: {{ first_component }},
{% else %}
  component: () => <Outlet />,
{% endif %}
});

{% for route in routes %}
const {{ route.key }}Route = createRoute({
  getParentRoute: () => rootRoute,
  path: {{ route.path | tojson }},
  component: {{ route.list_component }},
});

{% endfor %}
const routeTree = rootRoute.addChildren([
  indexRoute,
{% for route in routes %}
  {{ route.key }}Route,
{% endfor %}
]);

export const router = createRouter({ routeTree });

declare module "@tanstack/react-router" {
  interface Register {
    router: typeof router;
  }
}
