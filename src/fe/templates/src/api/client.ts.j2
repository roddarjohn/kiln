//
// Configures the openapi-ts client to attach the bearer token
// stored by glaze's AuthProvider on every request that declares
// bearer security. Token is read fresh on each call so login /
// logout transitions take effect without a page reload.

import { client } from "../_generated/client.gen";
{% if auth_enabled %}
const TOKEN_KEY = {{ token_key | tojson }};

client.setConfig({
  auth: () => {
    if (typeof window === "undefined") return undefined;
    return window.localStorage.getItem(TOKEN_KEY) ?? undefined;
  },
});
{% else %}
// No auth configured for this project; client uses defaults.
void client;
{% endif %}

export {};
