import { useNavigate, useSearch } from "@tanstack/react-router";
import {
  Button,
  Card,
  CardBody,
  CardHeader,
  Form,
  LoginLayout,
  Stack,
  Text,
  TextField,
  useAuth,
  useFormMutation,
} from "@roddarjohn/glaze";

import type {
  {{ auth.credentials_type }},
  {{ auth.session_type }},
} from "../_generated/types.gen";

export function Login() {
  const auth = useAuth<{{ auth.session_type }}, {{ auth.credentials_type }}>();
  const navigate = useNavigate();
  // ``redirect`` is set by the root ``beforeLoad`` when an
  // unauthenticated request bounces here, so a successful login
  // can drop the user back where they were headed.
  const search = useSearch({ from: "/login" });

  // ``useFormMutation`` reads field values from the native FormData
  // at submit time -- no per-field useState boilerplate.  Each
  // TextField gets a ``name`` matching the credentials shape so the
  // resulting object can be cast straight into the SDK type.
  const { onSubmit, submitting, error } = useFormMutation({
    mutationFn: async (input) => {
      await auth.login(input as unknown as {{ auth.credentials_type }});
      return null;
    },
    onSuccess: () => {
      const to =
        typeof search.redirect === "string" && search.redirect.length > 0
          ? search.redirect
          : "/";
      void navigate({ to, search: {} });
    },
  });

  return (
    <LoginLayout>
      <Card>
        <CardHeader
          title="Sign in"
{% if auth.login_hint %}
          description={{ auth.login_hint | tojson }}
{% endif %}
        />
        <CardBody>
          <Form onSubmit={onSubmit}>
            <Stack gap="3">
{% for field in auth.credentials_fields %}
              <TextField
                name={{ field | tojson }}
                label={{ (field[:1].upper() + field[1:]) | tojson }}
{% if field == "password" %}
                type="password"
                autoComplete="current-password"
{% else %}
                autoComplete={{ field | tojson }}
{% endif %}
                data-testid={{ ('login-' + field) | tojson }}
              />
{% endfor %}
              {error !== null ? (
                <Text size="sm" data-testid="login-error">
                  {error.message}
                </Text>
              ) : null}
              <Button
                type="submit"
                pending={submitting}
                data-testid="login-submit"
              >
                Sign in
              </Button>
            </Stack>
          </Form>
        </CardBody>
      </Card>
    </LoginLayout>
  );
}
