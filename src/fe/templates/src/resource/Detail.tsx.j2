{% else %}
{% for field in section.fields %}
        <div>
          <Text size="xs" tone="muted">{{ field.label }}</Text>
          <Text>{String(item.{{ field.name }} ?? "")}</Text>
        </div>
{% endfor %}
{% endif %}
