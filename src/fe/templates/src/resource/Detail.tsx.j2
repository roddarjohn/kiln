{% if has_update or actions %}
import { useNavigate, useParams, useRouter } from "@tanstack/react-router";
{% else %}
import { useParams, useRouter } from "@tanstack/react-router";
{% endif %}
import { useQuery } from "@tanstack/react-query";
import {
{% if has_update or actions %}
  Button,
{% endif %}
{% if sections | selectattr('fields') | list %}
  DataList,
{% endif %}
{% if sections | selectattr('title') | list %}
  Heading,
{% endif %}
  Link,
  PageHeader,
  Spinner,
  Stack,
} from "@roddarjohn/glaze";

import { {{ get_fn }} } from "../_generated/sdk.gen";

{% for section in sections %}
{% if section.component %}
import {{ '{' }} {{ pascal }}{{ loop.index }}Section {{ '}' }} from {{ section.component | tojson }};
{% endif %}
{% endfor %}

export function {{ pascal }}Detail() {
  // ``id`` comes from the route param ``/<key>/$id`` so the
  // detail page is deep-linkable.  All sibling pages (edit /
  // actions) live at sub-routes under the same ``$id`` prefix.
  const { id } = useParams({ from: {{ detail_path | tojson }} });
  const router = useRouter();
{% if has_update or actions %}
  const navigate = useNavigate();
{% endif %}

  const { data, isLoading } = useQuery({
    queryKey: [{{ key | tojson }}, "get", id],
    queryFn: async () => {
      const res = await {{ get_fn }}({ path: { id } });
      if (res.error || !res.data) {
        throw new Error("Failed to load {{ label_singular | lower }}.");
      }
      return res.data;
    },
    // Bubble fetch failures (e.g. 404) up to the route's
    // ``errorComponent`` so the user gets the styled fallback
    // rather than a silently-blank page.
    throwOnError: true,
  });

  if (isLoading) return <Spinner aria-label={{ ('Loading ' + label_singular | lower) | tojson }} />;
  if (!data) return null;

  const item = data;

  return (
    <Stack gap="4">
      <PageHeader
        breadcrumbs={
          // Back traverses the browser history stack so the user
          // returns to wherever they came from (list with filter
          // X applied, another resource detail, etc.) -- not a
          // hard-coded list URL.
          <Link
            variant="muted"
            onPress={() => router.history.back()}
          >
            &larr; Back
          </Link>
        }
        title={{ label_singular | tojson }}
{% if has_update or actions %}
        actions={
          <>
{% if has_update %}
            <Button
              variant="secondary"
              data-testid={{ ('edit-' + key + '-button') | tojson }}
              onPress={() => {
                void navigate({
                  to: {{ update_path | tojson }},
                  params: { id },
                });
              }}
            >
              Edit
            </Button>
{% endif %}
{% for action in actions %}
            <Button
              size="sm"
              data-testid={{ ('detail-' + action.name + '-' + key + '-button') | tojson }}
              onPress={() => {
                void navigate({
                  to: {{ action.path | tojson }},
                  params: { id },
                });
              }}
            >
              {{ action.label }}
            </Button>
{% endfor %}
          </>
        }
{% endif %}
      />
{% for section in sections %}
      <Stack gap="2">
{% if section.title %}
        <Heading level={2}>{{ section.title }}</Heading>
{% endif %}
{% if section.component %}
        <{{ pascal }}{{ loop.index }}Section item={item} />
{% else %}
        <DataList
          dividers
          items={[
{% for field in section.fields %}
            {
              id: {{ field.name | tojson }},
              label: {{ field.label | tojson }},
              value: String(item.{{ field.name }} ?? ""),
            },
{% endfor %}
          ]}
        />
{% endif %}
      </Stack>
{% endfor %}
    </Stack>
  );
}
