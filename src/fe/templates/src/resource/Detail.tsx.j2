{% if has_update or actions %}
import { useNavigate, useParams, useRouter } from "@tanstack/react-router";
{% else %}
import { useParams, useRouter } from "@tanstack/react-router";
{% endif %}
import { useSuspenseQuery } from "@tanstack/react-query";
import {
{% if has_update or actions %}
  Button,
{% endif %}
{% if sections | selectattr('fields') | list %}
  DataList,
{% endif %}
{% if sections | selectattr('title') | list %}
  Heading,
{% endif %}
  Link,
  PageHeader,
  Stack,
} from "@roddarjohn/glaze";

import { {{ get_fn }}Options } from "../_generated/@tanstack/react-query.gen";

{% for section in sections %}
{% if section.component %}
import {{ '{' }} {{ pascal }}{{ loop.index }}Section {{ '}' }} from {{ section.component | tojson }};
{% endif %}
{% endfor %}

export function {{ pascal }}Detail() {
  // ``id`` comes from the route param ``/<key>/$id`` so the
  // detail page is deep-linkable.  All sibling pages (edit /
  // actions) live at sub-routes under the same ``$id`` prefix.
  const { id } = useParams({ from: {{ detail_path | tojson }} });
  const router = useRouter();
{% if has_update or actions %}
  const navigate = useNavigate();
{% endif %}

  // ``useSuspenseQuery`` defers loading state to the route's
  // ``pendingComponent`` (a glaze ``<PageLoader>`` configured in
  // ``router.tsx``); errors propagate to ``errorComponent``.  No
  // per-page ``isLoading`` branches.
  const { data: item } = useSuspenseQuery(
    {{ get_fn }}Options({ path: { id } }),
  );

  return (
    <Stack gap="4">
      <PageHeader
        eyebrow={
          // Back traverses the browser history so the user returns
          // to wherever they came from (list with filters applied,
          // another resource detail, etc.) instead of hard-coding
          // the list URL.
          <Link
            variant="muted"
            onPress={() => router.history.back()}
          >
            &larr; Back
          </Link>
        }
{% if title_field %}
        title={item.{{ title_field }} ?? {{ label_singular | tojson }}}
{% else %}
        title={{ label_singular | tojson }}
{% endif %}
{% if subtitle_field %}
        subtitle={item.{{ subtitle_field }}}
{% endif %}
{% if has_update or actions %}
        actions={
          <>
{% if has_update %}
            <Button
              variant="secondary"
              data-testid={{ ('edit-' + key + '-button') | tojson }}
              onPress={() => {
                void navigate({
                  to: {{ update_path | tojson }},
                  params: { id },
                });
              }}
            >
              Edit
            </Button>
{% endif %}
{% for action in actions %}
            <Button
              size="sm"
              data-testid={{ ('detail-' + action.name + '-' + key + '-button') | tojson }}
              onPress={() => {
                void navigate({
                  to: {{ action.path | tojson }},
                  params: { id },
                });
              }}
            >
              {{ action.label }}
            </Button>
{% endfor %}
          </>
        }
{% endif %}
      />
{% for section in sections %}
      <Stack gap="2">
{% if section.title %}
        <Heading level={2}>{{ section.title }}</Heading>
{% endif %}
{% if section.component %}
        <{{ pascal }}{{ loop.index }}Section item={item} />
{% else %}
        <DataList
          dividers
          items={[
{% for field in section.fields %}
            {
              id: {{ field.name | tojson }},
              label: {{ field.label | tojson }},
              value: item.{{ field.name }},
            },
{% endfor %}
          ]}
        />
{% endif %}
      </Stack>
{% endfor %}
    </Stack>
  );
}
