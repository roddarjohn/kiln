import { {{ action.component }} } from "./actions/{{ action.component }}";
{% endfor %}

interface Props {
  id: string;
  close: () => void;
}

export function {{ pascal }}Detail({ id, close: _close }: Props) {
  const { data, isLoading } = useQuery({
    queryKey: [{{ key | tojson }}, "get", id],
    queryFn: async () => {
      const res = await {{ get_fn }}({ path: { id } });
      if (res.error || !res.data) {
        throw new Error("Failed to load {{ label_singular | lower }}.");
      }
      return res.data;
    },
  });

  if (isLoading) return <Spinner aria-label={{ ('Loading ' + label_singular | lower) | tojson }} />;
  if (!data) return null;

  const item = data;

  return (
    <Stack gap="4">
{% if actions %}
      <Inline gap="2">
{% for action in actions %}
        <DialogTrigger>
          <Button size="sm">{{ action.label }}</Button>
          <Dialog title={{ action.label | tojson }}>
            {({ close: closeDialog }) => (
              <{{ action.component }} item={item} close={closeDialog} />
            )}
          </Dialog>
        </DialogTrigger>
{% endfor %}
      </Inline>
{% endif %}
{% for section in sections %}
      <Stack gap="2">
{% if section.title %}
