{% if filters or has_sortable or page_size %}
import { useNavigate, useSearch } from "@tanstack/react-router";
{% else %}
import { useNavigate } from "@tanstack/react-router";
{% endif %}
{% if has_delete_row %}
import { useMutation, useQuery, useQueryClient } from "@tanstack/react-query";
{% else %}
import { useQuery } from "@tanstack/react-query";
{% endif %}
import {
{% if columns | selectattr('display', 'equalto', 'badge') | list %}
  Badge,
{% endif %}
  Button,
  Cell,
  Column,
  EmptyState,
{% if filters %}
  FilterBar,
{% endif %}
  PageHeader,
{% if page_size %}
  Pagination,
{% endif %}
  Row,
{% if filters | selectattr('type', 'equalto', 'select') | list %}
  Select,
  SelectItem,
{% endif %}
  Stack,
{% if filters | selectattr('type', 'equalto', 'boolean') | list %}
  Switch,
{% endif %}
  PageLoader,
  Table,
  TableBody,
  TableHeader,
{% if filters | selectattr('type', 'equalto', 'text') | list %}
  TextField,
{% endif %}
{% if has_delete_row %}
  toast,
{% endif %}
{% if page_size %}
  useServerPagination,
{% endif %}
} from "@roddarjohn/glaze";

{% if filters or has_sortable %}
import type {
{% if filters %}
  FilterDefinition,
{% endif %}
{% if has_sortable %}
  SortDescriptor,
{% endif %}
} from "@roddarjohn/glaze";
{% endif %}

import {
{% for fn in sdk_imports %}
  {{ fn }},
{% endfor %}
} from "../_generated/sdk.gen";

{% if filters %}
// Per-filter spec used to drive both the FilterBar UI and the
// list-fn body's filter expression.
const {{ pascal }}_FILTERS: FilterDefinition[] = [
{% for f in filters %}
  {
    id: {{ f.id | tojson }},
    label: {{ f.label | tojson }},
    clearValue: {% if f.type == "boolean" %}false{% else %}""{% endif %},
    isActive: (v) => {
{% if f.type == "boolean" %}
      return v === true;
{% elif f.type == "text" %}
      return typeof v === "string" && v.length > 0;
{% else %}
      return typeof v === "string" && v.length > 0;
{% endif %}
    },
    formatValue: (v) => {
{% if f.type == "boolean" %}
      return v === true ? "yes" : null;
{% else %}
      return typeof v === "string" && v.length > 0 ? v : null;
{% endif %}
    },
    renderControl: (value, onChange, _close) => (
{% if f.type == "boolean" %}
      <Switch
        selected={value === true}
        onChange={(next) => onChange(next)}
      >
        {{ f.label }}
      </Switch>
{% elif f.type == "select" %}
      <Select
        label={{ f.label | tojson }}
        selectedKey={typeof value === "string" ? value : null}
        onSelectionChange={(k) => onChange(k)}
      >
{% for opt in f.options %}
        <SelectItem id={{ opt | tojson }}>{{ opt }}</SelectItem>
{% endfor %}
      </Select>
{% else %}
      <TextField
        label={{ f.label | tojson }}
        value={typeof value === "string" ? value : ""}
        onChange={(next) => onChange(next)}
        autoFocus
      />
{% endif %}
    ),
  },
{% endfor %}
];

// Translate active FilterBar values into the BE's filter shape.
// Single condition stays a condition; multiple conditions are
// wrapped in `{ and: [...] }`. Empty -> undefined so the body
// omits the field entirely.
function build{{ pascal }}Filter(
  values: Record<string, unknown>,
): unknown {
  const conds: unknown[] = [];
{% for f in filters %}
  {
    const v = values[{{ f.id | tojson }}];
{% if f.type == "boolean" %}
    if (v === true) conds.push({ field: {{ f.field | tojson }}, op: {{ f.op | tojson }}, value: true });
{% else %}
    if (typeof v === "string" && v.length > 0) {
      conds.push({ field: {{ f.field | tojson }}, op: {{ f.op | tojson }}, value: v });
    }
{% endif %}
  }
{% endfor %}
  if (conds.length === 0) return undefined;
  if (conds.length === 1) return conds[0];
  return { and: conds };
}

{% endif %}
export function {{ pascal }}List() {
  // Filter / sort / pagination state lives in the URL via
  // TanStack Router's typed search params.  See ``validateSearch``
  // in ``src/router.tsx`` for the shape.  Create / detail / edit
  // / action surfaces are independent routes (``/<key>/new``,
  // ``/<key>/$id``, etc.) -- the list page navigates to them
  // rather than rendering them inline.
  const navigate = useNavigate();
{% if filters or has_sortable or page_size %}
  const search = useSearch({ from: {{ list_path | tojson }} });
{% endif %}
{% if has_delete_row %}
  const qc = useQueryClient();
{% endif %}

{% if page_size %}
  const pageState = search.page ?? 1;
{% endif %}
{% if has_sortable %}
  const sortDescriptor: SortDescriptor | undefined = search.sort
    ? {
        column: search.sort,
        direction: search.dir === "desc" ? "descending" : "ascending",
      }
    : undefined;
{% endif %}
{% if filters %}
  // FilterBar is controlled: values come from the URL and edits
  // round-trip through `navigate({ search })` so back-button works.
  const filterValues: Record<string, unknown> = {
{% for f in filters %}
    {{ f.id | tojson }}: search.{{ f.id }} ?? {% if f.type == "boolean" %}false{% else %}""{% endif %},
{% endfor %}
  };
  const onFilterChange = (id: string, value: unknown) => {
    void navigate({
      search: ((prev: Record<string, unknown>) => {
        const next: Record<string, unknown> = { ...prev };
        next[id] =
          value === "" || value === false || value === undefined
            ? undefined
            : value;
        // Reset to page 1 when filters change so the user doesn't
        // land on an empty page that no longer has results.
        next.page = undefined;
        return next;
      }) as never,
    });
  };
  const onClearAllFilters = () => {
    void navigate({
      search: ((prev: Record<string, unknown>) => {
        const next: Record<string, unknown> = { ...prev };
{% for f in filters %}
        next[{{ f.id | tojson }}] = undefined;
{% endfor %}
        next.page = undefined;
        return next;
      }) as never,
    });
  };
{% endif %}

  const { data, isLoading } = useQuery({
    queryKey: [
      {{ key | tojson }},
      "list",
{% if filters %}
      filterValues,
{% endif %}
{% if has_sortable %}
      sortDescriptor,
{% endif %}
{% if page_size %}
      pageState,
{% endif %}
    ],
    queryFn: async () => {
      const res = await {{ list_fn }}({
        body: {
{% if filters %}
          filter: build{{ pascal }}Filter(filterValues) as never,
{% endif %}
{% if has_sortable %}
          sort: sortDescriptor
            ? ([
                {
                  field: String(sortDescriptor.column),
                  dir:
                    sortDescriptor.direction === "descending" ? "desc" : "asc",
                },
              ] as never)
            : undefined,
{% endif %}
{% if page_size %}
          offset: (pageState - 1) * {{ page_size }},
          limit: {{ page_size }},
{% endif %}
        },
      });
      if (res.error || !res.data) {
        throw new Error("Failed to load {{ label_plural | lower }}.");
      }
      return res.data;
    },
  });

{% if page_size %}
  // Total comes from the server response; useServerPagination
  // bridges that into a `<Pagination>`-shaped props bundle.  The
  // page itself is URL-driven -- onPageChange writes back to
  // search.
  const pagination = useServerPagination({
    total: data?.total ?? 0,
    pageSize: {{ page_size }},
    page: pageState,
    onPageChange: (next) => {
      void navigate({
        search: ((prev: Record<string, unknown>) => ({
          ...prev,
          page: next === 1 ? undefined : next,
        })) as never,
      });
    },
  });
{% endif %}
{% if has_delete_row %}
  const deleteMut = useMutation({
    mutationFn: async (id: string) => {
      const res = await {{ delete_fn }}({ path: { id } });
      if (res.error) throw new Error("Delete failed.");
    },
    onSuccess: async () => {
      await qc.invalidateQueries({ queryKey: [{{ key | tojson }}] });
      toast.success({{ (label_singular + ' deleted.') | tojson }});
    },
    onError: (err) => {
      toast.error(err instanceof Error ? err.message : "Delete failed.");
    },
  });

{% endif %}
  if (isLoading) return <PageLoader label={{ ('Loading ' + label_plural | lower) | tojson }} />;

  const items = data?.items ?? [];

  return (
    <Stack gap="4">
      <PageHeader
        title={{ label_plural | tojson }}
{% if has_create_toolbar %}
        actions={
          <Button
            data-testid={{ ('create-' + key + '-button') | tojson }}
            onPress={() => {
              void navigate({ to: {{ create_path | tojson }} });
            }}
          >
            New {{ label_singular | lower }}
          </Button>
        }
{% endif %}
      />
{% if filters %}
      <FilterBar
        values={filterValues}
        onChange={onFilterChange}
        filters={ {{ pascal }}_FILTERS }
        onClearAll={onClearAllFilters}
      />
{% endif %}
      {items.length === 0 ? (
        <EmptyState
          title={{ ('No ' + label_plural | lower + ' yet') | tojson }}
{% if has_create_toolbar %}
          description="Create one to get started."
{% endif %}
        />
      ) : (
        <Table
          aria-label={{ label_plural | tojson }}
          data-testid={{ (key + '-table') | tojson }}
{% if row_click_detail %}
          onRowAction={(rowId) => {
            void navigate({
              to: {{ detail_path | tojson }},
              params: { id: String(rowId) },
            });
          }}
{% endif %}
{% if has_sortable %}
          sortDescriptor={sortDescriptor}
          onSortChange={(desc) => {
            void navigate({
              search: ((prev: Record<string, unknown>) => ({
                ...prev,
                sort: desc.column ? String(desc.column) : undefined,
                dir:
                  desc.direction === "descending" ? "desc" : "asc",
                // New sort -> back to the first page so the user
                // sees the top of the newly-ordered list.
                page: undefined,
              })) as never,
            });
          }}
{% endif %}
        >
          <TableHeader>
{% for col in columns %}
            <Column
              id={{ col.field | tojson }}
{% if col.is_first %}
              rowHeader
{% endif %}
{% if col.sortable %}
              allowsSorting
{% endif %}
            >
              {{ col.label }}
            </Column>
{% endfor %}
{% if has_delete_row or row_actions %}
            <Column id="actions">Actions</Column>
{% endif %}
          </TableHeader>
          <TableBody items={items}>
            {(item) => (
              <Row id={String(item.id)} data-testid={`{{ key }}-row-${item.id}`}>
{% for col in columns %}
                <Cell>
{% if col.display == 'badge' %}
                  <Badge tone={item.{{ col.field }} ? "success" : "neutral"}>
                    {item.{{ col.field }} ? "yes" : "no"}
                  </Badge>
{% else %}
                  {String(item.{{ col.field }} ?? "")}
{% endif %}
                </Cell>
{% endfor %}
{% if has_delete_row or row_actions %}
                <Cell>
{% if has_delete_row %}
                  <Button
                    variant="danger"
                    size="sm"
                    pending={
                      deleteMut.isPending && deleteMut.variables === item.id
                    }
                    onPress={() => {
                      deleteMut.mutate(String(item.id));
                    }}
                    data-testid={`delete-{{ key }}-${item.id}`}
                  >
                    Delete
                  </Button>
{% endif %}
{% for action in row_actions %}
                  {
{% if action.when %}
                  ({{ action.when }}) ? (
{% else %}
                  (
{% endif %}
                    <Button
                      size="sm"
                      data-testid={`{{ action.name }}-{{ key }}-${item.id}`}
                      onPress={() => {
                        void navigate({
                          to: {{ action.path | tojson }},
                          params: { id: String(item.id) },
                        });
                      }}
                    >
                      {{ action.label }}
                    </Button>
                  ){% if action.when %} : null{% endif %}
                  }
{% endfor %}
                </Cell>
{% endif %}
              </Row>
            )}
          </TableBody>
        </Table>
      )}
{% if page_size %}

      {pagination.totalPages > 1 ? (
        <Pagination
          page={pagination.page}
          // Prefer BE-supplied total_pages when available; fall back
          // to the client-side count from useServerPagination.
          totalPages={
            (data as { total_pages?: number } | undefined)?.total_pages ??
            pagination.totalPages
          }
          onPageChange={pagination.onPageChange}
        />
      ) : null}
{% endif %}
    </Stack>
  );
}
