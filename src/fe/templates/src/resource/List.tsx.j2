// ============================================================

{% if row_click_detail or filters or page_size or has_sortable %}
import { useState } from "react";
{% endif %}
{% if has_delete_row %}
import { useMutation, useQuery, useQueryClient } from "@tanstack/react-query";
{% else %}
import { useQuery } from "@tanstack/react-query";
{% endif %}
import {
{% if columns | selectattr('display', 'equalto', 'badge') | list %}
  Badge,
{% endif %}
  Button,
  Cell,
  Column,
{% if has_create_toolbar or row_click_detail %}
  Drawer,
  DrawerTrigger,
{% endif %}
{% if row_actions %}
  Dialog,
  DialogTrigger,
{% endif %}
  EmptyState,
{% if filters %}
  FilterBar,
{% endif %}
{% if has_create_toolbar and not filters %}
  Inline,
{% endif %}
{% if page_size %}
  Pagination,
{% endif %}
  Row,
{% if filters | selectattr('type', 'equalto', 'select') | list %}
  Select,
  SelectItem,
{% endif %}
  Spinner,
  Stack,
{% if filters | selectattr('type', 'equalto', 'boolean') | list %}
  Switch,
{% endif %}
  Table,
  TableBody,
  TableHeader,
{% if filters | selectattr('type', 'equalto', 'text') | list %}
  TextField,
{% endif %}
{% if has_delete_row %}
  toast,
{% endif %}
{% if filters %}
  useFilters,
{% endif %}
} from "@roddarjohn/glaze";

{% if filters %}
import type { FilterDefinition } from "@roddarjohn/glaze";
{% endif %}
{% if has_sortable %}
import type { SortDescriptor } from "react-aria-components";
{% endif %}

import {
{% for fn in sdk_imports %}
  {{ fn }},
{% endfor %}
} from "../_generated/sdk.gen";
{% if has_create_toolbar %}
import { Create{{ pascal }}Form } from "./Create{{ pascal }}Form";
{% endif %}
{% if row_click_detail %}
import { {{ detail_component }} } from "./{{ detail_component }}";
{% endif %}
{% for action in row_actions %}
import { {{ action.component }} } from "./actions/{{ action.component }}";
{% endfor %}

{% if filters %}
// Per-filter spec used to drive both the FilterBar UI and the
// list-fn body's filter expression.
const {{ pascal }}_FILTERS: FilterDefinition[] = [
{% for f in filters %}
  {
    id: {{ f.id | tojson }},
    label: {{ f.label | tojson }},
    clearValue: {% if f.type == "boolean" %}false{% else %}""{% endif %},
    isActive: (v) => {
{% if f.type == "boolean" %}
      return v === true;
{% elif f.type == "text" %}
      return typeof v === "string" && v.length > 0;
{% else %}
      return typeof v === "string" && v.length > 0;
{% endif %}
    },
    formatValue: (v) => {
{% if f.type == "boolean" %}
      return v === true ? "yes" : null;
{% else %}
      return typeof v === "string" && v.length > 0 ? v : null;
{% endif %}
    },
    renderControl: (value, onChange, _close) => (
{% if f.type == "boolean" %}
      <Switch
        selected={value === true}
        onChange={(next) => onChange(next)}
      >
        {{ f.label }}
      </Switch>
{% elif f.type == "select" %}
      <Select
        label={{ f.label | tojson }}
        selectedKey={typeof value === "string" ? value : null}
        onSelectionChange={(k) => onChange(k)}
      >
{% for opt in f.options %}
        <SelectItem id={{ opt | tojson }}>{{ opt }}</SelectItem>
{% endfor %}
      </Select>
{% else %}
      <TextField
        label={{ f.label | tojson }}
        value={typeof value === "string" ? value : ""}
        onChange={(next) => onChange(next)}
        autoFocus
      />
{% endif %}
    ),
  },
{% endfor %}
];

// Translate active FilterBar values into the BE's filter shape.
// Single condition stays a condition; multiple conditions are
// wrapped in `{ and: [...] }`. Empty -> undefined so the body
// omits the field entirely.
function build{{ pascal }}Filter(
  values: Record<string, unknown>,
): unknown {
  const conds: unknown[] = [];
{% for f in filters %}
  {
    const v = values[{{ f.id | tojson }}];
{% if f.type == "boolean" %}
    if (v === true) conds.push({ field: {{ f.field | tojson }}, op: {{ f.op | tojson }}, value: true });
{% else %}
    if (typeof v === "string" && v.length > 0) {
      conds.push({ field: {{ f.field | tojson }}, op: {{ f.op | tojson }}, value: v });
    }
{% endif %}
  }
{% endfor %}
  if (conds.length === 0) return undefined;
  if (conds.length === 1) return conds[0];
  return { and: conds };
}

{% endif %}
export function {{ pascal }}List() {
{% if has_delete_row %}
  const qc = useQueryClient();
{% endif %}
{% if row_click_detail %}
  const [openId, setOpenId] = useState<string | null>(null);
{% endif %}
{% if filters %}
  const filterState = useFilters({{ pascal }}_FILTERS);
{% endif %}
{% if has_sortable %}
  const [sortDescriptor, setSortDescriptor] = useState<
    SortDescriptor | undefined
  >(undefined);
{% endif %}
{% if page_size %}
  const [page, setPage] = useState(1);
  const PAGE_SIZE = {{ page_size }};
{% endif %}

  const { data, isLoading } = useQuery({
    queryKey: [
      {{ key | tojson }},
      "list",
{% if filters %}
      filterState.values,
{% endif %}
{% if has_sortable %}
      sortDescriptor,
{% endif %}
{% if page_size %}
      page,
{% endif %}
    ],
    queryFn: async () => {
      const res = await {{ list_fn }}({
        body: {
{% if filters %}
          filter: build{{ pascal }}Filter(filterState.values) as never,
{% endif %}
{% if has_sortable %}
          sort: sortDescriptor
            ? ([
                {
                  field: String(sortDescriptor.column),
                  dir:
                    sortDescriptor.direction === "descending" ? "desc" : "asc",
                },
              ] as never)
            : undefined,
{% endif %}
{% if page_size %}
          offset: (page - 1) * PAGE_SIZE,
          limit: PAGE_SIZE,
{% endif %}
        },
      });
      if (res.error || !res.data) {
        throw new Error("Failed to load {{ label_plural | lower }}.");
      }
      return res.data;
    },
  });

{% if has_delete_row %}
  const deleteMut = useMutation({
    mutationFn: async (id: string) => {
      const res = await {{ delete_fn }}({ path: { id } });
      if (res.error) throw new Error("Delete failed.");
    },
    onSuccess: async () => {
      await qc.invalidateQueries({ queryKey: [{{ key | tojson }}] });
      toast.success({{ (label_singular + ' deleted.') | tojson }});
    },
    onError: (err) => {
      toast.error(err instanceof Error ? err.message : "Delete failed.");
    },
  });

{% endif %}
  if (isLoading) return <Spinner aria-label={{ ('Loading ' + label_plural | lower) | tojson }} />;

  const items = data?.items ?? [];

  return (
    <Stack gap="3">
{% if filters %}
      <FilterBar
        values={filterState.values}
        onChange={filterState.onChange}
        filters={ {{ pascal }}_FILTERS }
        onClearAll={filterState.onClearAll}
{% if has_create_toolbar %}
        actions={
          <DrawerTrigger>
            <Button data-testid={{ ('create-' + key + '-button') | tojson }}>
              New {{ label_singular | lower }}
            </Button>
            <Drawer
              side="right"
              size="md"
              title={{ ('New ' + label_singular | lower) | tojson }}
            >
              {({ close }) => <Create{{ pascal }}Form close={close} />}
            </Drawer>
          </DrawerTrigger>
        }
{% endif %}
      />
{% elif has_create_toolbar %}
      <Inline gap="2" justify="end">
        <DrawerTrigger>
          <Button data-testid={{ ('create-' + key + '-button') | tojson }}>
            New {{ label_singular | lower }}
          </Button>
          <Drawer
            side="right"
            size="md"
            title={{ ('New ' + label_singular | lower) | tojson }}
          >
            {({ close }) => <Create{{ pascal }}Form close={close} />}
          </Drawer>
        </DrawerTrigger>
      </Inline>

{% endif %}
      {items.length === 0 ? (
        <EmptyState
          title={{ ('No ' + label_plural | lower + ' yet') | tojson }}
{% if has_create_toolbar %}
          description="Create one to get started."
{% endif %}
        />
      ) : (
        <Table
          aria-label={{ label_plural | tojson }}
          data-testid={{ (key + '-table') | tojson }}
{% if row_click_detail %}
          onRowAction={(rowId) => {
            setOpenId(String(rowId));
          }}
{% endif %}
{% if has_sortable %}
          sortDescriptor={sortDescriptor}
          onSortChange={setSortDescriptor}
{% endif %}
        >
          <TableHeader>
{% for col in columns %}
            <Column
              id={{ col.field | tojson }}
{% if col.is_first %}
              rowHeader
{% endif %}
{% if col.sortable %}
              allowsSorting
{% endif %}
            >
              {{ col.label }}
            </Column>
{% endfor %}
{% if has_delete_row or row_actions %}
            <Column id="actions">Actions</Column>
{% endif %}
          </TableHeader>
          <TableBody items={items}>
            {(item) => (
              <Row id={String(item.id)} data-testid={`{{ key }}-row-${item.id}`}>
{% for col in columns %}
                <Cell>
{% if col.display == 'badge' %}
                  <Badge tone={item.{{ col.field }} ? "success" : "neutral"}>
                    {item.{{ col.field }} ? "yes" : "no"}
                  </Badge>
{% else %}
                  {String(item.{{ col.field }} ?? "")}
{% endif %}
                </Cell>
{% endfor %}
{% if has_delete_row or row_actions %}
                <Cell>
{% if has_delete_row %}
                  <Button
                    variant="danger"
                    size="sm"
                    pending={
                      deleteMut.isPending && deleteMut.variables === item.id
                    }
                    onPress={() => {
                      deleteMut.mutate(String(item.id));
                    }}
                    data-testid={`delete-{{ key }}-${item.id}`}
                  >
                    Delete
                  </Button>
{% endif %}
{% for action in row_actions %}
                  {
{% if action.when %}
                  ({{ action.when }}) ? (
{% else %}
                  (
{% endif %}
                    <DialogTrigger>
                      <Button size="sm" data-testid={`{{ action.name }}-{{ key }}-${item.id}`}>
                        {{ action.label }}
                      </Button>
                      <Dialog title={{ action.label | tojson }}>
                        {({ close }) => <{{ action.component }} item={item} close={close} />}
                      </Dialog>
                    </DialogTrigger>
                  ){% if action.when %} : null{% endif %}
                  }
{% endfor %}
                </Cell>
{% endif %}
              </Row>
            )}
          </TableBody>
        </Table>
      )}
{% if page_size %}

      {data && data.total > PAGE_SIZE ? (
        <Pagination
          page={page}
          // Prefer the BE-supplied total_pages; fall back to a
          // client-side ceil for older BEs that haven't shipped
          // the field yet.
          totalPages={
            (data as { total_pages?: number }).total_pages ??
            Math.max(1, Math.ceil(data.total / PAGE_SIZE))
          }
          onPageChange={setPage}
        />
      ) : null}
{% endif %}
{% if row_click_detail %}

      <DrawerTrigger
        open={openId !== null}
        onOpenChange={(open) => {
          if (!open) setOpenId(null);
        }}
      >
        {/* Controlled overlay: the row click sets `openId`, which
            opens this Drawer. The hidden button satisfies
            DrawerTrigger's two-children contract. */}
        <button type="button" hidden aria-hidden />
        <Drawer
          side="right"
          size="md"
          title={{ (label_singular + ' details') | tojson }}
        >
          {({ close }) =>
            openId !== null ? (
              <{{ detail_component }}
                id={openId}
                close={() => {
                  setOpenId(null);
                  close();
                }}
              />
            ) : null
          }
        </Drawer>
      </DrawerTrigger>
{% endif %}
    </Stack>
  );
}
