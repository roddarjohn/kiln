[project]
name = "{{ name }}"
version = "0.1.0"
description = "{{ description }}"
requires-python = ">=3.14"
dependencies = [
  "fastapi>=0.115",
  "sqlalchemy[asyncio]>=2.0",
  "asyncpg>=0.29",
  "uvicorn[standard]>=0.30",
  "kiln-generator",
]

[dependency-groups]
dev = [
  "httpx>=0.28.1",
  "pytest>=8",
  "pytest-asyncio>=1.3.0",
  "ruff>=0.15.5",
]

[tool.ruff]
line-length = 80
exclude = ["{{ package_prefix }}"]

[tool.ruff.lint]
select = ["ALL"]
ignore = [
  "COM812",
  "ISC001",
  "D203",
  "D213",
  "D100",
  "D104",
  "AIR",
  "DJ",
  "FAST",
  "NPY",
  "PD",
  "INT",
  "CPY",
]

[tool.pytest.ini_options]
addopts = "-v"
asyncio_mode = "auto"
