# ============================================================
# AUTOGENERATED by kiln_root from bootstrap.jsonnet.
#
# This file is a one-shot scaffold.  Edit it freely -- most
# apps add seed/worker/migration recipes here.  But running
# `just bootstrap` (defined below) overwrites this file
# verbatim; kiln_root has no merge semantics, so treat any
# post-bootstrap edits as "re-apply on next re-bootstrap".
# ============================================================

config    := "config/project.jsonnet"
bootstrap := "bootstrap.jsonnet"
out       := "{{ package_prefix }}"

export PYTHONPATH := "."

# List available recipes
default:
    @just --list

# Re-run the kiln_root bootstrap.  Overwrites the bootstrap-shaped
# files (main.py, pyproject.toml, justfile, .gitignore,
# .python-version, config/project.jsonnet, config/<module>.jsonnet);
# any post-bootstrap edits to those files will be lost.
bootstrap:
    uv run foundry generate --target kiln_root --config {% raw %}{{ bootstrap }}{% endraw %} --out .

# Generate routes and schemas from the kiln config
generate:
    uv run foundry generate --target kiln --config {% raw %}{{ config }}{% endraw %} --out {% raw %}{{ out }}{% endraw %} --clean

alias g := generate

# Start the dev server (hot-reload)
serve:
    uv run uvicorn main:app --reload

alias s := serve

# Generate then start the dev server
fresh: generate serve

alias f := fresh

# Dump the OpenAPI schema for the running app shape to openapi.json
openapi:
    uv run python -c "import json, main; print(json.dumps(main.app.openapi(), indent=2))" > openapi.json

# Run linter and formatter checks
lint:
    uv run --group dev ruff check . && uv run --group dev ruff format --check .

# Auto-fix lint and formatting
fix:
    uv run --group dev ruff check --fix . && uv run --group dev ruff format .

# Run the test suite (user + generated)
test:
    uv run --group dev pytest tests/ {% raw %}{{ out }}{% endraw %}/tests/
