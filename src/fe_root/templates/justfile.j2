# ============================================================
# AUTOGENERATED by fe_root from bootstrap.jsonnet.
#
# This file is a one-shot scaffold.  Edit it freely -- most
# apps add seed/build/preview recipes here.  But running
# `just bootstrap` (defined below) overwrites this file
# verbatim; fe_root has no merge semantics, so treat any
# post-bootstrap edits as "re-apply on next re-bootstrap".
# ============================================================

config    := "config/fe.jsonnet"
bootstrap := "bootstrap.jsonnet"

# List available recipes
default:
    @just --list

# Install JS dependencies (run once after cloning, then again
# whenever package.json changes).
setup:
    yarn install

# Re-run the fe_root bootstrap.  Overwrites the bootstrap-shaped
# files (package.json, justfile, tsconfig.json, vite.config.ts,
# index.html, src/main.tsx, src/App.tsx, src/index.css,
# .gitignore, .nvmrc, config/fe.jsonnet); any post-bootstrap
# edits to those files will be lost.
bootstrap:
    foundry generate --target fe_root --config {% raw %}{{ bootstrap }}{% endraw %} --out .

# Regenerate ``openapi-ts.config.ts`` from the kiln-side fe
# config, then run @hey-api/openapi-ts to produce the typed
# client + React-Query hooks.
generate: openapi-ts-config
    yarn openapi-ts

alias g := generate

# Regenerate just ``openapi-ts.config.ts`` from
# ``config/fe.jsonnet``.  Run on its own when you want to
# inspect the openapi-ts config without firing the TS codegen.
openapi-ts-config:
    foundry generate --target fe --config {% raw %}{{ config }}{% endraw %} --out .

# Start the Vite dev server (hot-reload).
dev:
    yarn dev

alias d := dev

# Generate then start the dev server.
fresh: generate dev

alias f := fresh

# Build the production bundle into ``dist/``.
build:
    yarn build

# Type-check the project (no emit).
type-check:
    yarn type-check
