from __future__ import annotations

from ingot.auth import session_auth

from {{ session_module }} import {{ session_name }}
{% if store_name %}
from {{ store_module }} import {{ store_name }}
{% endif %}

get_session = session_auth(
    {{ session_name }},
    {{ sources }},
    secret_env="{{ secret_env }}",
    algorithm="{{ algorithm }}",
{%- if "bearer" in sources %}
    token_url="{{ token_url }}",
{%- endif %}
{%- if "cookie" in sources %}
    cookie_name="{{ cookie_name }}",
{%- endif %}
{%- if store_name %}
    store={{ store_name }},
{%- endif %}
)

__all__ = ["get_session"]
