"""FastAPI JWT authentication dependency.

Generated by ``kiln init``.  Modify as needed.

The secret is read from the environment variable named in
``JWT_SECRET`` (or whatever ``AuthConfig.secret_env`` is set to).
"""

from __future__ import annotations

import os
from typing import Annotated

import jwt
from fastapi import Depends, HTTPException, status
from fastapi.security import OAuth2PasswordBearer

oauth2_scheme = OAuth2PasswordBearer(tokenUrl="/auth/token")


async def get_current_user(
    token: Annotated[str, Depends(oauth2_scheme)],
) -> dict:
    """Validate a JWT bearer token and return the decoded payload.

    Args:
        token: Bearer token extracted by FastAPI's security scheme.

    Returns:
        Decoded JWT payload as a plain dict.

    Raises:
        HTTPException: 401 if the token is invalid or the secret
            env var is not set.
    """
    try:
        secret = os.environ["JWT_SECRET"]
        return jwt.decode(token, secret, algorithms=["HS256"])
    except (jwt.InvalidTokenError, KeyError) as exc:
        raise HTTPException(
            status_code=status.HTTP_401_UNAUTHORIZED,
            detail="Could not validate credentials",
            headers={"WWW-Authenticate": "Bearer"},
        ) from exc
