# OpenTelemetry runtime dependencies for the generated app.
# Add these to your project's pyproject.toml / requirements file --
# kiln does not install them itself.  Pinned versions match the
# coherent release pair shipped together by the OpenTelemetry
# project; bump in lockstep when upgrading.

opentelemetry-api=={{ otel_core_version }}
opentelemetry-sdk=={{ otel_core_version }}
opentelemetry-exporter-otlp-proto-http=={{ otel_core_version }}
{% if exporter == "otlp_grpc" %}
opentelemetry-exporter-otlp-proto-grpc=={{ otel_core_version }}
{% endif %}
{% if instrument_fastapi %}
opentelemetry-instrumentation-fastapi=={{ otel_instrumentation_version }}
{% endif %}
{% if instrument_sqlalchemy %}
opentelemetry-instrumentation-sqlalchemy=={{ otel_instrumentation_version }}
{% endif %}
{% if instrument_httpx %}
opentelemetry-instrumentation-httpx=={{ otel_instrumentation_version }}
{% endif %}
{% if instrument_logging %}
opentelemetry-instrumentation-logging=={{ otel_instrumentation_version }}
{% endif %}
