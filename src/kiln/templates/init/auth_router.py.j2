from __future__ import annotations

from fastapi import APIRouter

from ingot.auth import issue_bearer_token

from {{ creds_module }} import {{ creds_name }}
from {{ validate_module }} import {{ validate_name }}

router = APIRouter()


@router.post("{{ token_url }}")
def create_token(credentials: {{ creds_name }}) -> dict[str, str]:
    """Validate credentials and return an OAuth2-shaped JWT response.

    Args:
        credentials: Parsed login request body.

    Returns:
        ``{"access_token": <jwt>, "token_type": "bearer"}`` on success.

    Raises:
        HTTPException: 401 if ``{{ validate_name }}`` returns ``None``.
    """
    return issue_bearer_token(
        {{ validate_name }}(credentials),
        secret_env="{{ secret_env }}",
        algorithm="{{ algorithm }}",
    )
