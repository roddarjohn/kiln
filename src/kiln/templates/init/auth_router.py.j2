from __future__ import annotations

from typing import Annotated

from fastapi import APIRouter, Depends, Response

from ingot.auth import clear_session, issue_session

from {{ creds_module }} import {{ creds_name }}
from {{ validate_module }} import {{ validate_name }}
from {{ session_module }} import {{ session_name }}
{% if store_name %}
from {{ store_module }} import {{ store_name }}
{% endif %}

from .dependencies import get_session

router = APIRouter()


@router.post("{{ token_url }}")
def create_token(
    response: Response,
    credentials: {{ creds_name }},
) -> dict:
    """Validate credentials and issue a session token.

    Args:
        response: Outgoing response; receives Set-Cookie when
            ``"cookie"`` is in the configured sources.
        credentials: Parsed login request body.

    Returns:
        OAuth2-shaped body when ``"bearer"`` is in sources,
        otherwise ``{"ok": True}``.

    Raises:
        HTTPException: 401 if ``{{ validate_name }}`` returns ``None``.
    """
    return issue_session(
        response,
        {{ validate_name }}(credentials),
        sources={{ sources }},
        secret_env="{{ secret_env }}",
        algorithm="{{ algorithm }}",
{%- if "cookie" in sources %}
        cookie_name="{{ cookie_name }}",
        cookie_secure={{ cookie_secure }},
        cookie_samesite="{{ cookie_samesite }}",
{%- endif %}
    )


@router.get("{{ token_url }}")
def read_session(
    session: Annotated[{{ session_name }}, Depends(get_session)],
) -> {{ session_name }}:
    """Return the current authenticated session as JSON.

    The shared ``get_session`` dep enforces authentication and
    (when a :class:`ingot.auth.SessionStore` is wired in) the
    deny-list, so no extra work is needed here -- a missing,
    invalid, or revoked token yields HTTP 401 before this body
    runs.
    """
    return session


@router.post("{{ token_url }}/logout")
{% if store_name -%}
async def logout(
    response: Response,
    session: Annotated[{{ session_name }}, Depends(get_session)],
) -> dict:
    """Revoke the session server-side, then clear the transport.

    Calls ``{{ store_name }}.revoke(session)`` before
    :func:`ingot.auth.clear_session`; revoke-first means a failure
    leaves the token non-verifying rather than zombie-valid.
    """
    await {{ store_name }}.revoke(session)
    return clear_session(
        response,
        sources={{ sources }},
{%- if "cookie" in sources %}
        cookie_name="{{ cookie_name }}",
        cookie_secure={{ cookie_secure }},
        cookie_samesite="{{ cookie_samesite }}",
{%- endif %}
    )
{%- else -%}
def logout(response: Response) -> dict:
    """Clear the session.

    For the cookie source the Set-Cookie header deletes the cookie;
    for bearer the client is expected to discard its token.
    """
    return clear_session(
        response,
        sources={{ sources }},
{%- if "cookie" in sources %}
        cookie_name="{{ cookie_name }}",
        cookie_secure={{ cookie_secure }},
        cookie_samesite="{{ cookie_samesite }}",
{%- endif %}
    )
{%- endif %}
