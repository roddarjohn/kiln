from __future__ import annotations

from fastapi import APIRouter, Response

from ingot.auth import clear_auth_cookie, set_auth_cookie

from {{ creds_module }} import {{ creds_name }}
from {{ validate_module }} import {{ validate_name }}

router = APIRouter()


@router.post("{{ token_url }}")
def create_token(
    response: Response,
    credentials: {{ creds_name }},
) -> dict[str, bool]:
    """Validate credentials and set an httpOnly auth cookie.

    Args:
        response: Outgoing response; receives the Set-Cookie header.
        credentials: Parsed login request body.

    Returns:
        ``{"ok": True}`` on success.

    Raises:
        HTTPException: 401 if ``{{ validate_name }}`` returns ``None``.
    """
    set_auth_cookie(
        response,
        {{ validate_name }}(credentials),
        cookie_name="{{ cookie_name }}",
        secret_env="{{ secret_env }}",
        algorithm="{{ algorithm }}",
        secure={{ cookie_secure }},
        samesite="{{ cookie_samesite }}",
    )
    return {"ok": True}


@router.post("{{ token_url }}/logout")
def logout(response: Response) -> dict[str, bool]:
    """Clear the auth cookie."""
    clear_auth_cookie(
        response,
        cookie_name="{{ cookie_name }}",
        secure={{ cookie_secure }},
        samesite="{{ cookie_samesite }}",
    )
    return {"ok": True}
