from __future__ import annotations

import datetime
import os

import jwt
from fastapi import APIRouter, Depends, HTTPException, status
from fastapi.security import OAuth2PasswordRequestForm

from {{ vcf_module }} import {{ vcf_name }}

router = APIRouter()


@router.post("{{ token_url }}")
def create_token(
    form_data: OAuth2PasswordRequestForm = Depends(),
) -> dict[str, str]:
    """Exchange username/password credentials for a JWT.

    Args:
        form_data: OAuth2 password grant form fields.

    Returns:
        A dict with ``access_token`` and ``token_type`` keys.

    Raises:
        HTTPException: 401 if credentials are invalid.
    """
    payload = {{ vcf_name }}(
        form_data.username, form_data.password
    )
    if payload is None:
        raise HTTPException(
            status_code=status.HTTP_401_UNAUTHORIZED,
            detail="Invalid credentials",
            headers={"WWW-Authenticate": "Bearer"},
        )
    payload.setdefault(
        "exp",
        datetime.datetime.now(tz=datetime.UTC)
        + datetime.timedelta(minutes=30),
    )
    secret = os.environ["{{ secret_env }}"]
    token = jwt.encode(payload, secret, algorithm="{{ algorithm }}")
    return {"access_token": token, "token_type": "bearer"}
