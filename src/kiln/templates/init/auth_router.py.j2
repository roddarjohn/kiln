from __future__ import annotations

from fastapi import APIRouter, Depends, Response
from fastapi.security import OAuth2PasswordRequestForm

from ingot.auth import clear_auth_cookie, set_auth_cookie

from {{ vcf_module }} import {{ vcf_name }}

router = APIRouter()


@router.post("{{ token_url }}")
def create_token(
    response: Response,
    form_data: OAuth2PasswordRequestForm = Depends(),
) -> dict[str, bool]:
    """Verify credentials and set an httpOnly auth cookie.

    Args:
        response: Outgoing response; receives the Set-Cookie header.
        form_data: OAuth2 password grant form fields.

    Returns:
        ``{"ok": True}`` on success.

    Raises:
        HTTPException: 401 if credentials are invalid.
    """
    set_auth_cookie(
        response,
        {{ vcf_name }}(form_data.username, form_data.password),
        cookie_name="{{ cookie_name }}",
        secret_env="{{ secret_env }}",
        algorithm="{{ algorithm }}",
        secure={{ cookie_secure }},
        samesite="{{ cookie_samesite }}",
    )
    return {"ok": True}


@router.post("{{ token_url }}/logout")
def logout(response: Response) -> dict[str, bool]:
    """Clear the auth cookie."""
    clear_auth_cookie(
        response,
        cookie_name="{{ cookie_name }}",
        secure={{ cookie_secure }},
        samesite="{{ cookie_samesite }}",
    )
    return {"ok": True}
