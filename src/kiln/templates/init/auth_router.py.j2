from __future__ import annotations

from typing import Annotated

from fastapi import APIRouter, Depends, Response

from ingot.auth import (
    LoginResponse,
    OkResponse,
    clear_session,
    issue_session,
)

from {{ creds_module }} import {{ creds_name }}
from {{ validate_module }} import {{ validate_name }}
from {{ session_module }} import {{ session_name }}
{% if store_name %}
from {{ store_module }} import {{ store_name }}
{% endif %}

{% if has_telemetry %}
from {{ telemetry_module }}.decorators import scrub_current_span_attributes
{% endif %}

from .dependencies import get_session

router = APIRouter()


{% if has_telemetry %}
# Span-attribute keys that *would* otherwise carry the credentials
# payload or the issued-session payload.  Listed once so the login
# and logout handlers stay in sync, and so a future body-capture
# hook adding new keys updates one tuple.
_AUTH_SCRUB_KEYS = (
    "http.request.body",
    "http.response.body",
    "http.request.header.authorization",
    "http.request.header.cookie",
    "http.response.header.set-cookie",
)


{% endif %}
@router.post("{{ token_url }}")
def create_token(
    response: Response,
    credentials: {{ creds_name }},
) -> LoginResponse | OkResponse:
    """Validate credentials and issue a session token.

    Raises HTTP 401 if ``{{ validate_name }}`` returns ``None``.
    """
{% if has_telemetry %}
    scrub_current_span_attributes(*_AUTH_SCRUB_KEYS)
{% endif %}
    return issue_session(
        response,
        {{ validate_name }}(credentials),
        sources={{ sources }},
        secret_env="{{ secret_env }}",
        algorithm="{{ algorithm }}",
{%- if "cookie" in sources %}
        cookie_name="{{ cookie_name }}",
        cookie_secure={{ cookie_secure }},
        cookie_samesite="{{ cookie_samesite }}",
{%- endif %}
    )


@router.get("{{ token_url }}")
def read_session(
    session: Annotated[{{ session_name }}, Depends(get_session)],
) -> {{ session_name }}:
    """Return the current authenticated session as JSON.

    ``get_session`` enforces auth (and the deny-list when a
    :class:`ingot.auth.SessionStore` is wired in) before this
    body runs, so a missing, invalid, or revoked token yields
    HTTP 401.
    """
    return session


@router.post("{{ token_url }}/logout")
{% if store_name -%}
async def logout(
    response: Response,
    session: Annotated[{{ session_name }}, Depends(get_session)],
) -> OkResponse:
    """Revoke server-side, then clear the transport.

    Revoke-before-clear: a revoke failure leaves the token
    non-verifying rather than zombie-valid.
    """
{% if has_telemetry %}
    scrub_current_span_attributes(*_AUTH_SCRUB_KEYS)
{% endif %}
    await {{ store_name }}.revoke(session)
    return clear_session(
        response,
        sources={{ sources }},
{%- if "cookie" in sources %}
        cookie_name="{{ cookie_name }}",
        cookie_secure={{ cookie_secure }},
        cookie_samesite="{{ cookie_samesite }}",
{%- endif %}
    )
{%- else -%}
def logout(response: Response) -> OkResponse:
    """Clear the session transport.

    Cookie source: ``Set-Cookie`` header deletes the cookie.
    Bearer source: client discards its token.
    """
{% if has_telemetry %}
    scrub_current_span_attributes(*_AUTH_SCRUB_KEYS)
{% endif %}
    return clear_session(
        response,
        sources={{ sources }},
{%- if "cookie" in sources %}
        cookie_name="{{ cookie_name }}",
        cookie_secure={{ cookie_secure }},
        cookie_samesite="{{ cookie_samesite }}",
{%- endif %}
    )
{%- endif %}
