{% set _extra %}
Reads its DSN from the ``{{ url_env }}`` environment variable
(the same variable the ``{{ db_key }}`` SQLAlchemy session
reads).  The worker opens its *own* asyncpg connection because
pgqueuer ``LISTEN``s for new-job notifications, which requires a
long-lived connection that cannot be returned to a pool between
batches.

Tasks live in ``{{ tasks_module }}`` — every coroutine function
decorated with :func:`ingot.task` there is registered on the
worker's :class:`pgqueuer.PgQueuer`.  Per-task tuning
(``concurrency_limit``, ``retry_timer_seconds``, etc.) goes on
the decorator.

Run with::

    python -m {{ worker_module }}

To split work across pod classes, point different deployments
at different task modules (one ``tasks_module`` per kiln config,
or override ``TASKS_MODULE`` below at the deployment layer).

The pgqueuer schema must already be installed in the database;
run ``pgq install`` once per environment before starting the
worker.
{% endset %}
{{ file_header("pgqueuer worker entrypoint", extra=_extra) }}

from __future__ import annotations

import asyncio
import importlib
import os

from pgqueuer import PgQueuer

from ingot import open_worker_driver, register_module_tasks

#: Dotted path of the user-authored module containing
#: ``@task``-decorated coroutine functions.  Override at the
#: deployment layer (e.g. via a small wrapper script) to run
#: a worker against a different task module without regenerating.
TASKS_MODULE = "{{ tasks_module }}"


async def main() -> None:
    """Open a worker driver, register every tagged task, run forever."""
    tasks_mod = importlib.import_module(TASKS_MODULE)
    async with open_worker_driver(os.environ["{{ url_env }}"]) as driver:
        pgq = PgQueuer(driver)
        register_module_tasks(pgq, tasks_mod)
        await pgq.run()


if __name__ == "__main__":
    asyncio.run(main())
