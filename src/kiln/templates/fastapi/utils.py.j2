from __future__ import annotations

import json
from typing import Any

from fastapi import HTTPException, status
from pydantic import BaseModel
from sqlalchemy import Select, and_, or_
from sqlalchemy.ext.asyncio import AsyncSession

#: Mapping from operator suffix to SQLAlchemy column method or
#: comparison.  Used by :func:`apply_filters` to build WHERE
#: clauses from a Pydantic filter schema.
_FILTER_OPS: dict[str, str] = {
    "eq": "__eq__",
    "neq": "__ne__",
    "gt": "__gt__",
    "gte": "__ge__",
    "lt": "__lt__",
    "lte": "__le__",
    "contains": "contains",
    "starts_with": "startswith",
    "in": "in_",
}

#: Operators that are called as column methods (e.g.
#: ``col.contains(val)``) rather than dunder comparisons.
_METHOD_OPS = {"contains", "startswith", "in_"}


def apply_filters(
    stmt: Select,
    filters: BaseModel,
    model: type,
    *,
    allowed_fields: set[str] | None = None,
) -> Select:
    """Build WHERE clauses from a Pydantic filter model.

    Supports two complementary filter mechanisms:

    **Flat query parameters** — field names follow the convention
    ``{column}_{operator}`` (e.g. ``name_contains``,
    ``age_gt``).  A field without an operator suffix is treated
    as ``eq``.  Only fields whose value is not ``None`` are
    applied.  These are always combined with AND.

    **Structured ``filter`` parameter** — a JSON string
    expressing arbitrarily nested AND/OR trees::

        {"and": [
            {"field": "status", "op": "eq", "value": "active"},
            {"or": [
                {"field": "role", "op": "eq", "value": "admin"},
                {"field": "role", "op": "in", "value": ["a", "b"]}
            ]}
        ]}

    When both are provided the flat params and the structured
    expression are AND'd together.

    Args:
        stmt: The SQLAlchemy SELECT statement to filter.
        filters: A Pydantic model whose non-None fields
            describe filter conditions.
        model: The SQLAlchemy model class providing columns.
        allowed_fields: Optional whitelist of column names
            permitted in structured filter expressions.  When
            ``None`` all model attributes are accessible.

    Returns:
        The statement with WHERE clauses applied.

    """
    clauses: list[Any] = []

    # --- Flat query-parameter filters (always AND) ---
    filter_data = filters.model_dump(exclude_none=True)
    filter_json = filter_data.pop("filter", None)
    for name, value in filter_data.items():
        col_name, op_method = _parse_filter_field(name)
        col = getattr(model, col_name)
        clauses.append(getattr(col, op_method)(value))

    # --- Structured JSON filter expression ---
    if filter_json is not None:
        expr = (
            json.loads(filter_json)
            if isinstance(filter_json, str)
            else filter_json
        )
        tree_clause = _build_filter_tree(
            expr, model, allowed_fields
        )
        if tree_clause is not None:
            clauses.append(tree_clause)

    if not clauses:
        return stmt
    return stmt.where(and_(*clauses))


def _build_filter_tree(
    node: dict[str, Any],
    model: type,
    allowed_fields: set[str] | None,
) -> Any:
    """Recursively build a SQLAlchemy clause from a filter tree.

    A node is either a **combiner** (``{"and": [...]}`` or
    ``{"or": [...]}``) or a **leaf** condition
    (``{"field": "name", "op": "eq", "value": "x"}``).

    Args:
        node: A dict representing a filter node.
        model: The SQLAlchemy model class.
        allowed_fields: Optional whitelist of permitted fields.

    Returns:
        A SQLAlchemy clause element, or ``None`` for empty
        combiner lists.

    Raises:
        HTTPException: With 400 status for invalid filter
            expressions (unknown fields, bad operators, etc.).

    """
    if "and" in node:
        children = [
            _build_filter_tree(child, model, allowed_fields)
            for child in node["and"]
        ]
        children = [c for c in children if c is not None]
        if not children:
            return None
        return and_(*children)

    if "or" in node:
        children = [
            _build_filter_tree(child, model, allowed_fields)
            for child in node["or"]
        ]
        children = [c for c in children if c is not None]
        if not children:
            return None
        return or_(*children)

    # Leaf condition
    field_name = node.get("field")
    op = node.get("op", "eq")
    value = node.get("value")

    if not field_name:
        raise HTTPException(
            status_code=status.HTTP_400_BAD_REQUEST,
            detail="Filter condition missing 'field'.",
        )

    if allowed_fields and field_name not in allowed_fields:
        raise HTTPException(
            status_code=status.HTTP_400_BAD_REQUEST,
            detail=f"Filter field '{field_name}' is not allowed.",
        )

    if op not in _FILTER_OPS:
        raise HTTPException(
            status_code=status.HTTP_400_BAD_REQUEST,
            detail=f"Unknown filter operator '{op}'.",
        )

    col = getattr(model, field_name, None)
    if col is None:
        raise HTTPException(
            status_code=status.HTTP_400_BAD_REQUEST,
            detail=f"Model has no column '{field_name}'.",
        )

    op_method = _FILTER_OPS[op]
    return getattr(col, op_method)(value)


def _parse_filter_field(
    name: str,
) -> tuple[str, str]:
    """Derive column name and operator from a filter field name.

    Tries suffixes longest-first so ``starts_with`` is matched
    before ``with``.

    Args:
        name: The Pydantic field name, e.g. ``"age_gt"`` or
            ``"name_starts_with"``.

    Returns:
        ``(column_name, sqlalchemy_method)`` tuple.

    """
    for suffix, method in sorted(
        _FILTER_OPS.items(),
        key=lambda kv: len(kv[0]),
        reverse=True,
    ):
        if name.endswith(f"_{suffix}"):
            col = name[: -(len(suffix) + 1)]
            return col, method
    # No suffix → equality
    return name, "__eq__"


async def get_object_from_query_or_404(
    db: AsyncSession,
    stmt: Any,
    *,
    detail: str = "Not found",
) -> Any:
    """Execute *stmt* and return the first row, or raise HTTP 404.

    Args:
        db: The async database session.
        stmt: A SQLAlchemy selectable statement.
        detail: The error message for the 404 response.

    Returns:
        The first row from the result set.

    Raises:
        HTTPException: With status 404 when no row is found.

    """
    result = await db.execute(stmt)
    row = result.scalars().one_or_none()
    if row is None:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail=detail,
        )
    return row


def assert_rowcount(
    result: Any,
    *,
    expected: int = 1,
    status_code: int = status.HTTP_404_NOT_FOUND,
    detail: str = "Not found",
) -> None:
    """Raise HTTPException when *result* did not affect *expected* rows.

    Args:
        result: SQLAlchemy ``CursorResult`` from an ``execute()`` call.
        expected: Number of rows that must have been affected.
        status_code: HTTP status code for the raised exception.
        detail: The error message for the response.

    Raises:
        HTTPException: When ``result.rowcount`` does not equal *expected*.

    """
    if result.rowcount != expected:
        raise HTTPException(status_code=status_code, detail=detail)
