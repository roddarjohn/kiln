@pytest.mark.asyncio()
async def test_{{ fn_name }}_not_found(
    client: AsyncClient,
    mock_db: AsyncMock,
) -> None:
    """{{ tc.method | upper }} {{ url }} returns 404 for missing resource."""
    mock_result = MagicMock()
    mock_scalars = MagicMock()
{% if tc.method == "delete" or tc.method == "patch" %}
    mock_result.rowcount = 0
{% else %}
    mock_scalars.one_or_none.return_value = None
    mock_result.scalars.return_value = mock_scalars
{% endif %}
    mock_db.execute = AsyncMock(return_value=mock_result)
{% if "{" in tc.path and tc.method == "post" %}
    url = "{{ route_prefix }}/" + str(_MISSING_UUID) + "{{ tc.path.split('}', 1)[1] }}"
    response = await client.post(url{% if tc.has_request_body %}, json={}{% endif %})
{% elif tc.method == "get" %}
    url = "{{ route_prefix }}/" + str(_MISSING_UUID)
    response = await client.get(url)
{% elif tc.method == "patch" %}
    url = "{{ route_prefix }}/" + str(_MISSING_UUID)
    response = await client.patch(url{% if tc.has_request_body %}, json={}{% endif %})
{% elif tc.method == "delete" %}
    url = "{{ route_prefix }}/" + str(_MISSING_UUID)
    response = await client.delete(url)
{% endif %}
    assert response.status_code == 404
{% endif %}
{% if tc.status_invalid %}

@pytest.mark.asyncio()
async def test_{{ fn_name }}_invalid_body(
    client: AsyncClient,
) -> None:
    """{{ tc.method | upper }} {{ url }} returns 422 for invalid body."""
{% if tc.method == "post" and "{" not in tc.path %}
    response = await client.post(
        "{{ url }}",
        json={"__invalid__": True},
    )
{% elif tc.method == "post" %}
    url = "{{ route_prefix }}/" + str(_SAMPLE_VALUES["{{ pk_py_type }}"]) + "{{ tc.path.split('}', 1)[1] }}"
    response = await client.post(url, json={"__invalid__": True})
{% elif tc.method == "patch" %}
    # PATCH with invalid type values
    url = "{{ route_prefix }}/" + str(_SAMPLE_VALUES["{{ pk_py_type }}"])
    response = await client.patch(
        url,
        json={"__invalid__": True},
    )
{% endif %}
{% if tc.method == "patch" %}
    # PATCH accepts partial updates; only truly invalid types
    # trigger 422.  Adjust this test for your schema.
    assert response.status_code in (200, 422)
{% else %}
    assert response.status_code == 422
{% endif %}
{% endif %}
