    response = await client.post(url{% if tc.has_request_body %}, json=body{% endif %})
{% else %}
    response = await client.post("{{ url }}"{% if tc.has_request_body %}, json=body{% endif %})
{% endif %}
{% elif tc.method == "patch" %}
{% if tc.has_request_body and tc.request_fields %}
    body = {
{% for f in tc.request_fields %}
        "{{ f.name }}": {% if f.py_type == "uuid.UUID" %}str(_SAMPLE_VALUES["uuid.UUID"]){% elif f.py_type == "str" %}"test"{% elif f.py_type == "int" %}1{% elif f.py_type == "float" %}1.0{% elif f.py_type == "bool" %}True{% elif f.py_type == "datetime" %}"2024-01-01T00:00:00"{% elif f.py_type == "date" %}"2024-01-01"{% elif "dict" in f.py_type %}{}{% else %}"test"{% endif %},
