_SAMPLE_VALUES: dict[str, object] = {
    "uuid.UUID": uuid.uuid4(),
    "str": "test",
    "int": 1,
    "float": 1.0,
    "bool": True,
    "datetime": "2024-01-01T00:00:00",
    "date": "2024-01-01",
}

_MISSING_UUID = uuid.uuid4()


def _sample(py_type: str) -> object:
    """Return a sample value for a Python type string."""
    return _SAMPLE_VALUES.get(py_type, "test")


