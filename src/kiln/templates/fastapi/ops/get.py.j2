@router.get("/{{ '{' }}{{ pk_name }}{{ '}' }}"{% if has_resource_schema %}, response_model={{ model_name }}Resource{% endif %})
async def get_{{ model_lower }}(
    {{ pk_name }}: {{ pk_py_type }},
    db: Annotated[AsyncSession, Depends({{ get_db_fn }})],
{% if has_auth and requires_auth %}
    current_user: Annotated[dict, Depends(get_current_user)],
{% endif %}
) -> {% if has_resource_schema %}{{ model_name }}Resource{% else %}object{% endif %}:
    """Get a {{ model_name }} by {{ pk_name }}."""
    obj = await get_object_from_query_or_404(
        db,
        select({{ model_name }}).where({{ model_name }}.{{ pk_name }} == {{ pk_name }}),
        detail="{{ model_name }} not found",
    )
{% if has_resource_schema %}
    return to_{{ model_lower }}_resource(obj)
{% else %}
    return obj
{% endif %}
