@router.{{ http_method }}("{{ route_path }}", response_model={{ response_model }})
async def list_{{ model_lower }}(
    db: Annotated[AsyncSession, Depends({{ get_db_fn }})],
{% for dep in extra_deps|default([]) %}
    {{ dep }}
{% endfor %}
{% for param in extra_params %}
    {{ param }}
{% endfor %}
) -> {{ return_type }}:
    """List {{ model_name }} records."""
    stmt = select({{ model_name }})
{% for modifier in query_modifiers %}
    {{ modifier }}
{% endfor %}
{% if result_expression %}
    {{ result_expression }}
{% elif serializer_fn %}
    result = await db.execute(stmt)
    return [{{ serializer_fn }}(obj) for obj in result.scalars()]
{% else %}
    result = await db.execute(stmt)
    return list(result.scalars().all())
{% endif %}
