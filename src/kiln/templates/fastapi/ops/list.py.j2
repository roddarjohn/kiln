{% extends "fastapi/handler_default.py.j2" %}
{% block body %}
    stmt = select({{ model_name }})
{% for modifier in query_modifiers %}
    {{ modifier }}
{% endfor %}
{% if result_expression %}
    {{ result_expression }}
{% else %}
    result = await db.execute(stmt)
    return [{{ serializer_fn }}(obj) for obj in result.scalars()]
{% endif %}
{% endblock %}
