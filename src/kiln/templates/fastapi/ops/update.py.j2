{% extends "fastapi/handler_default.py.j2" %}
{% block body %}
    result = await db.execute(
        update({{ model_name }})
        .where({{ model_name }}.{{ pk_name }} == {{ pk_name }})
        .values(**body.model_dump(exclude_unset=True))
    )
    assert_rowcount(result, detail="{{ model_name }} not found")
    await db.commit()
{% endblock %}
