{% extends "fastapi/handler_default.py.j2" %}
{% block body %}
    stmt = select({{ model_name }})
{% if load_options|default([]) %}
    stmt = stmt.options(
{% for opt in load_options %}
        {{ opt }},
{% endfor %}
    )
{% endif %}
{% if has_filter %}
    if body.filter is not None:
        stmt = apply_filters(stmt, body.filter, {{ model_name }})
{% endif %}
{% if has_sort %}
    stmt = apply_ordering(
        stmt,
        body.sort,
        {{ model_name }},
        default_field="{{ default_sort_field }}",
        default_dir="{{ default_sort_dir }}",
    )
{% endif %}
{% if pagination_mode == "keyset" %}
    stmt, page_size = apply_keyset_pagination(
        stmt,
        {{ model_name }},
        cursor=body.cursor,
        cursor_field="{{ cursor_field }}",
        page_size=body.page_size,
        max_page_size={{ max_page_size }},
    )
    result = await db.execute(stmt)
    rows = list(result.scalars())
    has_more = len(rows) > page_size
    items = rows[:page_size]
    next_cursor = (
        str(getattr(items[-1], "{{ cursor_field }}"))
        if has_more and items
        else None
    )
    return {{ model_name }}Page(
        items=[{{ serializer_fn }}(obj) for obj in items],
        next_cursor=next_cursor,
    )
{% elif pagination_mode == "offset" %}
    stmt, count_stmt, _ = apply_offset_pagination(
        stmt,
        offset=body.offset,
        limit=body.limit,
        max_page_size={{ max_page_size }},
    )
    total = (await db.execute(count_stmt)).scalar_one()
    result = await db.execute(stmt)
    return {{ model_name }}Page(
        items=[{{ serializer_fn }}(obj) for obj in result.scalars()],
        total=total,
    )
{% else %}
    result = await db.execute(stmt)
    return [{{ serializer_fn }}(obj) for obj in result.scalars()]
{% endif %}
{% endblock %}
