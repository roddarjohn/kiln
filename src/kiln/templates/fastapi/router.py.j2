from __future__ import annotations

from fastapi import APIRouter

{% for r in routes %}
from .{{ r.module_name }} import router as {{ r.alias }}
{% endfor %}

router = APIRouter()
{% for r in routes %}
router.include_router({{ r.alias }})
{% endfor %}
